@using System
@{
    // helper functions for active menu detection - KEPT EXACTLY AS PROVIDED
    string CurrentController() => ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string CurrentAction() => ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string ActiveForController(string controller)
    {
        return string.Equals(CurrentController(), controller, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    string ActiveForControllerAction(string controller, string action)
    {
        return (string.Equals(CurrentController(), controller, StringComparison.OrdinalIgnoreCase)
                && string.Equals(CurrentAction(), action, StringComparison.OrdinalIgnoreCase))
                ? "active"
                : string.Empty;
    }

    bool ControllerIs(string controller) => string.Equals(CurrentController(), controller, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html dir="ltr" lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BelieveIn</title>
    <link rel="icon" type="image/png" sizes="16x16" href="~/Admin/assets/images/1400.png" />
    <link href="~/Admin/assets/libs/flot/css/float-chart.css" rel="stylesheet" />
    <link href="~/Admin/dist/css/style.min.css" rel="stylesheet" />

    <style>
        /* Ensures the sidebar is fixed and doesn't push content off-screen */
        .left-sidebar {
            display: flex !important;
            flex-direction: column !important;
            height: 100vh !important;
            position: fixed;
            z-index: 10;
        }

        .scroll-sidebar {
            flex: 1 1 auto !important;
            overflow-y: auto !important;
        }

        .sidebar-footer {
            padding: 15px;
            background: #1c2228;
            border-top: 1px solid rgba(255,255,255,0.05);
            margin-top: auto;
        }

        .logout-box {
            display: flex;
            align-items: center;
            padding: 10px 15px;
            border-radius: 8px;
            color: #94a3b8 !important;
            text-decoration: none;
            transition: 0.3s;
            background: rgba(255,255,255,0.03);
        }

            .logout-box:hover {
                background: rgba(234, 88, 12, 0.15);
                color: #ea580c !important;
            }

            .logout-box i {
                margin-right: 10px;
                color: #ef4444;
            }

        @@media (max-width: 767px) {
            .topbar .top-navbar .navbar-header {
                display: flex !important;
                align-items: center;
                width: 100%;
                justify-content: normal !important;
            }
            /* Ensuring the toggler doesn't hug the edge too tightly */
            .nav-toggler {
                padding: 10px;
                display: flex;
                align-items: center;
            }
        }
    </style>
</head>

<body>
    <div class="preloader">
        <div class="lds-ripple">
            <div class="lds-pos"></div>
            <div class="lds-pos"></div>
        </div>
    </div>

    <div id="main-wrapper" data-layout="vertical" data-navbarbg="skin5" data-sidebartype="full"
         data-sidebar-position="fixed" data-header-position="fixed" data-boxed-layout="full">

        <header class="topbar" data-navbarbg="skin5">
            <nav class="navbar top-navbar navbar-expand-md navbar-dark">
                <div class="navbar-header" data-logobg="skin5">
                    <a class="nav-toggler waves-effect waves-light d-block d-md-none" href="javascript:void(0)">
                        <i class="ti-menu ti-close"></i>
                    </a>

                    <a class="navbar-brand" href="/home/index">
                        <b class="logo-icon ps-2">
                            <img src="~/Admin/assets/images/1400.png" alt="logo" class="light-logo" width="25" />
                        </b>
                        <span class="logo-text ms-2">
                            <img src="~/Admin/assets/images/believeintext.png" alt="text" class="light-logo" />
                        </span>
                    </a>
                </div>
                <div class="" id="navbarSupportedContent" data-navbarbg="skin5">
                    <ul class="navbar-nav float-start me-auto">
                        <li class="nav-item d-none d-lg-block">
                            <a class="nav-link sidebartoggler waves-effect waves-light" href="javascript:void(0)" data-sidebartype="mini-sidebar">
                                <i class="mdi mdi-menu font-24"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <aside class="left-sidebar" data-sidebarbg="skin5">
            <div class="scroll-sidebar">
                <nav class="sidebar-nav">
                    <ul id="sidebarnav" class="pt-4">

                        <li class="sidebar-item @(ControllerIs("Home") ? "selected" : "")">
                            <a class="sidebar-link waves-effect waves-dark" asp-controller="Home" asp-action="Index">
                                <i class="mdi mdi-view-dashboard"></i><span class="hide-menu">Dashboard</span>
                            </a>
                        </li>

                        <li class="sidebar-item @(ControllerIs("Categories") ? "selected" : "")">
                            <a class="sidebar-link waves-effect waves-dark" asp-controller="Categories" asp-action="Index">
                                <i class="mdi mdi-receipt"></i><span class="hide-menu">Categories</span>
                            </a>
                        </li>

                        <li class="sidebar-item @(ControllerIs("Quotes") ? "selected" : "")">
                            <a class="sidebar-link waves-effect waves-dark" asp-controller="Quotes" asp-action="Index">
                                <i class="mdi mdi-chart-bubble"></i><span class="hide-menu">Affirmations</span>
                            </a>
                        </li>

                        <li class="sidebar-item @(ControllerIs("Users") ? "selected" : "")">
                            <a class="sidebar-link waves-effect waves-dark" asp-controller="Users" asp-action="Index">
                                <i class="mdi mdi-border-inside"></i><span class="hide-menu">Users</span>
                            </a>
                        </li>

                        <li class="sidebar-item @(ControllerIs("Reports") ? "selected" : "")">
                            <a class="sidebar-link has-arrow waves-effect waves-dark"
                               href="javascript:void(0)"
                               aria-expanded="@(ControllerIs("Reports") ? "true" : "false")">
                                <i class="mdi mdi-receipt"></i>
                                <span class="hide-menu">Reports</span>
                            </a>
                            <ul aria-expanded="@(ControllerIs("Reports") ? "true" : "false")"
                                class="collapse first-level @(ControllerIs("Reports") ? "in" : "")">

                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "Dashboard"))">
                                    <a href="/Reports/Dashboard" class="sidebar-link">
                                        <i class="mdi mdi-note-outline"></i>
                                        <span class="hide-menu">Users</span>
                                    </a>
                                </li>
                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "ErrorLogs"))">
                                    <a href="/Reports/ErrorLogs" class="sidebar-link">
                                        <i class="mdi mdi-note-plus"></i>
                                        <span class="hide-menu">Error Logs</span>
                                    </a>
                                </li>
                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "UserEngagement"))">
                                    <a href="/Reports/UserEngagement" class="sidebar-link">
                                        <i class="mdi mdi-note-plus"></i>
                                        <span class="hide-menu">User Engagement</span>
                                    </a>
                                </li>
                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "ContentAnalytics"))">
                                    <a href="/Reports/ContentAnalytics" class="sidebar-link">
                                        <i class="mdi mdi-note-plus"></i>
                                        <span class="hide-menu">Content Analytics</span>
                                    </a>
                                </li>
                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "Subscriptions"))">
                                    <a href="/Reports/Subscriptions" class="sidebar-link">
                                        <i class="mdi mdi-note-plus"></i>
                                        <span class="hide-menu">Subscription</span>
                                    </a>
                                </li>
                                <li class="sidebar-item @(ActiveForControllerAction("Reports", "ScheduleReport"))">
                                    <a href="/Reports/ScheduleReport" class="sidebar-link">
                                        <i class="mdi mdi-note-plus"></i>
                                        <span class="hide-menu">Schedule Report</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </nav>
            </div>

            <div class="sidebar-footer">
                <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display:none;">
                    @Html.AntiForgeryToken()
                </form>
                <a href="javascript:void(0)" onclick="confirmLogout();" class="logout-box">
                    <i class="mdi mdi-power"></i>
                    <span class="hide-menu">Sign Out</span>
                </a>
            </div>
        </aside>

        <div class="page-wrapper">
            <div class="container-fluid">
                @RenderBody()
            </div>

            <footer class="footer text-center">
                &copy; @DateTime.Now.Year BelieveIn App. All rights reserved.
            </footer>
        </div>
    </div>

    <script src="~/Admin/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/Admin/assets/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/js/sidebarmenu.js"></script>
    <script src="~/Admin/assets/libs/perfect-scrollbar/dist/perfect-scrollbar.jquery.min.js"></script>
    <script src="~/Admin/dist/js/waves.js"></script>
    <script src="~/Admin/dist/js/custom.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmLogout() {
            Swal.fire({
                title: 'Confirm Sign Out',
                text: "Are you sure you want to logout?",
                icon: 'warning',
                background: '#1f262d',
                color: '#fff',
                showCancelButton: true,
                confirmButtonColor: '#ea580c',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Logout'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logoutForm').submit();
                }
            });
        }
           $(document).ready(function() {
            // Force active state for the parent
            $('.collapse.in').parents('li').addClass('active');

            // Manual click handler if the template script fails
            $('.has-arrow').on('click', function (e) {
                e.preventDefault();
                var $el = $(this).parent().find('ul').first();
                if ($el.hasClass('in')) {
                    $el.removeClass('in').attr('aria-expanded', 'false');
                    $(this).attr('aria-expanded', 'false');
                } else {
                    $el.addClass('in').attr('aria-expanded', 'true');
                    $(this).attr('aria-expanded', 'true');
                }
            });
        });

    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>