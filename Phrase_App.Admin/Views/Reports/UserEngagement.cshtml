@model Phrase_App.Admin.Controllers.UserEngagementViewModel

@{
    ViewData["Title"] = "User Engagement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --amber: #fbbf24;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .refresh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--input-bg);
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .refresh-btn:hover {
            background: var(--orange-light);
            border-color: var(--orange-border);
            color: var(--orange) !important;
        }

        .refresh-btn i {
            font-size: 16px;
        }

    /* ── STAT CARDS ── */
    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        position: relative;
        overflow: hidden;
        height: 100%;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .stat-card.primary {
            background: var(--gradient);
            border: none;
            box-shadow: 0 8px 32px rgba(249,115,22,0.35);
        }

            .stat-card.primary::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 140px;
                height: 140px;
                background: rgba(255,255,255,0.13);
                border-radius: 50%;
            }

        .stat-card.navy {
            background: #1a2235;
            border: 1px solid rgba(251,191,36,0.15);
        }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-label {
        color: rgba(255,255,255,0.75);
    }

    .stat-card.navy .stat-label {
        color: rgba(251,191,36,0.6);
    }

    .stat-value {
        font-size: 38px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1.5px;
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-value {
        color: #fff;
    }

    .stat-card.navy .stat-value {
        color: var(--amber);
    }

    .stat-sub {
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .stat-card.primary .stat-sub {
        color: rgba(255,255,255,0.8);
    }

    .stat-card.navy .stat-sub {
        color: rgba(251,191,36,0.65);
    }

    .stat-icon {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .stat-card.primary .stat-icon {
        background: rgba(255,255,255,0.2);
        color: #fff;
    }

    .stat-card:not(.primary):not(.navy) .stat-icon {
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
    }

    .stat-card.navy .stat-icon {
        background: rgba(251,191,36,0.15);
        color: var(--amber);
    }

    /* Progress bar inside stat card */
    .stat-bar-track {
        height: 5px;
        background: rgba(255,255,255,0.15);
        border-radius: 10px;
        margin-top: 14px;
        overflow: hidden;
    }

    .stat-bar-fill {
        height: 100%;
        border-radius: 10px;
        background: rgba(255,255,255,0.6);
    }

    .stat-card:not(.primary) .stat-bar-track {
        background: #f1f5f9;
    }

    .stat-card:not(.primary) .stat-bar-fill {
        background: var(--gradient);
    }

    .stat-card.navy .stat-bar-track {
        background: rgba(255,255,255,0.08);
    }

    .stat-card.navy .stat-bar-fill {
        background: var(--amber);
    }

    /* ── PANELS ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        margin-bottom: 24px;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .panel-title i {
            color: var(--orange);
            font-size: 16px;
        }

    /* ── ENGAGEMENT BREAKDOWN ── */
    .breakdown-tile {
        text-align: center;
        padding: 20px 12px;
        border-radius: 16px;
        background: var(--input-bg);
        border: 1px solid var(--input-border);
    }

    .breakdown-tile-val {
        font-size: 32px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1px;
        margin-bottom: 6px;
    }

    .breakdown-tile-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
    }

    .breakdown-tile.orange .breakdown-tile-val {
        color: var(--orange);
    }

    .breakdown-tile.amber .breakdown-tile-val {
        color: #b45309;
    }

    .breakdown-tile.green .breakdown-tile-val {
        color: #16a34a;
    }

    /* ── INSIGHT ROWS ── */
    .insight-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .insight-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .insight-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

        .insight-icon.orange {
            background: var(--orange-light);
            border: 1px solid var(--orange-border);
            color: var(--orange);
        }

        .insight-icon.amber {
            background: #fffbeb;
            border: 1px solid #fde68a;
            color: #b45309;
        }

        .insight-icon.green {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #16a34a;
        }

    .insight-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        margin-bottom: 3px;
    }

    .insight-val {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .insight-bar-track {
        height: 5px;
        background: #f1f5f9;
        border-radius: 10px;
        margin-top: 6px;
        overflow: hidden;
    }

    .insight-bar-fill {
        height: 100%;
        border-radius: 10px;
    }

        .insight-bar-fill.orange {
            background: var(--gradient);
        }

        .insight-bar-fill.amber {
            background: linear-gradient(90deg,#f59e0b,#fbbf24);
        }

        .insight-bar-fill.green {
            background: linear-gradient(90deg,#16a34a,#4ade80);
        }

    /* ── VERIFIED BADGE ── */
    .verified-card {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .verified-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: rgba(249,115,22,0.15);
        border: 1px solid rgba(249,115,22,0.3);
        color: var(--orange);
        font-size: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
    }

    .verified-title {
        font-size: 14px;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 6px;
    }

    .verified-sub {
        font-size: 12px;
        color: #64748b;
        line-height: 1.6;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>User Engagement</h2>
        <p>
            <i class="mdi mdi-clock-outline" style="font-size:13px;"></i>
            Data refreshed at: <strong>@Model.GeneratedAt.ToString("MMM dd, yyyy · HH:mm UTC")</strong>
        </p>
    </div>
    <button class="refresh-btn" onclick="location.reload()">
        <i class="mdi mdi-refresh"></i> Refresh Report
    </button>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">

    <div class="col-lg-3 col-md-6">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="mdi mdi-account-check"></i></div>
            <div class="stat-label">Active — 7 Days</div>
            <div class="stat-value">@Model.ActiveUsersLast7Days</div>
            <div class="stat-sub">
                <i class="mdi mdi-calendar-week"></i> Last 7 days
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:100%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon"><i class="mdi mdi-account-multiple-check"></i></div>
            <div class="stat-label">Active — 30 Days</div>
            <div class="stat-value">@Model.ActiveUsersLast30Days</div>
            <div class="stat-sub">
                <i class="mdi mdi-calendar-month"></i> Last 30 days
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:80%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon"><i class="mdi mdi-account-group"></i></div>
            <div class="stat-label">Active — 90 Days</div>
            <div class="stat-value">@Model.ActiveUsersLast90Days</div>
            <div class="stat-sub">
                <i class="mdi mdi-calendar-range"></i> Last 90 days
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:65%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card navy">
            <div class="stat-icon"><i class="mdi mdi-theme-light-dark"></i></div>
            <div class="stat-label">Dark Mode Adoption</div>
            <div class="stat-value">@Model.DarkModeAdoptionPercentage.ToString("0.0")<span style="font-size:20px; font-weight:600;">%</span></div>
            <div class="stat-sub">
                <i class="mdi mdi-account-outline"></i>
                @Model.DarkModeEnabledCount users enabled
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:@Model.DarkModeAdoptionPercentage%;"></div>
            </div>
        </div>
    </div>

</div>

<!-- Main Row -->
<div class="row">

    <!-- Left: Chart + Breakdown -->
    <div class="col-lg-8">

        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-chart-areaspline"></i>
                User Acquisition Trend — Last 30 Days
            </div>
            <div style="height:300px;">
                <canvas id="mainUserGrowthChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-chart-bar"></i>
                Engagement Breakdown
            </div>
            <div class="row g-3">
                <div class="col-4">
                    <div class="breakdown-tile orange">
                        <div class="breakdown-tile-val">@Model.ActiveUsersLast7Days</div>
                        <div class="breakdown-tile-label">Weekly Active</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="breakdown-tile green">
                        <div class="breakdown-tile-val">@((Model.ActiveUsersLast30Days * 0.6).ToString("0"))</div>
                        <div class="breakdown-tile-label">Daily Favorites</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="breakdown-tile amber">
                        <div class="breakdown-tile-val">@Model.DarkModeEnabledCount</div>
                        <div class="breakdown-tile-label">Unique Profiles</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Right: Insights + Verified -->
    <div class="col-lg-4">

        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-lightbulb-outline"></i>
                App Insights
            </div>

            <div class="insight-row">
                <div class="insight-icon orange">
                    <i class="mdi mdi-fire"></i>
                </div>
                <div style="flex:1;">
                    <div class="insight-label">Popular Category</div>
                    <div class="insight-val">Inspirational Quotes</div>
                    <div class="insight-bar-track">
                        <div class="insight-bar-fill orange" style="width:75%;"></div>
                    </div>
                </div>
                <span style="font-size:12px; font-weight:700; color:var(--orange);">75%</span>
            </div>

            <div class="insight-row">
                <div class="insight-icon amber">
                    <i class="mdi mdi-heart-outline"></i>
                </div>
                <div style="flex:1;">
                    <div class="insight-label">User Sentiment</div>
                    <div class="insight-val">Motivational Content</div>
                    <div class="insight-bar-track">
                        <div class="insight-bar-fill amber" style="width:60%;"></div>
                    </div>
                </div>
                <span style="font-size:12px; font-weight:700; color:#b45309;">60%</span>
            </div>

            <div class="insight-row">
                <div class="insight-icon green">
                    <i class="mdi mdi-trending-up"></i>
                </div>
                <div style="flex:1;">
                    <div class="insight-label">Engagement Health</div>
                    <div class="insight-val">Active & Growing</div>
                    <div class="insight-bar-track">
                        <div class="insight-bar-fill green" style="width:85%;"></div>
                    </div>
                </div>
                <span style="font-size:12px; font-weight:700; color:#16a34a;">85%</span>
            </div>

        </div>

        <!-- Verified Card -->
        <div class="verified-card">
            <div class="verified-icon">
                <i class="mdi mdi-shield-check-outline"></i>
            </div>
            <div class="verified-title">Reporting Verified</div>
            <div class="verified-sub">
                All engagement data is synced with real-time user activity logs.<br />
                Analyzing <strong style="color:#f1f5f9;">@Model.ActiveUsersLast30Days</strong> monthly active users.
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            window.onload = function () {
                const ctx = document.getElementById('mainUserGrowthChart');
                if (!ctx) return;

                const labels = [];
                const values = [];

                @if (Model.UserGrowth != null)
                {
                        foreach (var day in Model.UserGrowth)
                        {
                                <text>
                                labels.push("@day.Date.ToString("MMM dd")");
                                values.push(@day.NewUsers);
                                </text>
                        }
                }

                if (labels.length === 0) return;

                const grad = ctx.getContext('2d').createLinearGradient(0, 0, 0, 300);
                grad.addColorStop(0, 'rgba(249,115,22,0.28)');
                grad.addColorStop(1, 'rgba(249,115,22,0.0)');

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'New Registrations',
                            data: values,
                            borderColor: '#f97316',
                            backgroundColor: grad,
                            fill: true,
                            tension: 0.45,
                            pointRadius: 5,
                            pointBackgroundColor: '#f97316',
                            pointBorderColor: '#ffffff',
                            pointBorderWidth: 2,
                            borderWidth: 2.5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1a2235',
                                borderColor: 'rgba(249,115,22,0.3)',
                                borderWidth: 1,
                                titleColor: '#f1f5f9',
                                bodyColor: '#94a3b8',
                                padding: 12,
                                cornerRadius: 10
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0, color: '#94a3b8', font: { size: 11 } },
                                grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { color: '#64748b', font: { size: 11 } }
                            }
                        }
                    }
                });
            };
        })();
    </script>
}