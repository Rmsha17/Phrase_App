@model Phrase_App.Admin.Controllers.DashboardReportViewModel
@{
    ViewData["Title"] = "Reports Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="page-title text-uppercase font-weight-bold mb-0">Analytics & Insights</h4>
                <p class="text-muted small">Comprehensive platform overview and system status.</p>
            </div>
            <button class="btn btn-outline-primary btn-sm" onclick="window.print()">
                <i class="mdi mdi-printer"></i> Export PDF
            </button>
        </div>
    </div>

    <div class="row">
        <div class="row mt-4 mb-5">
            <div class="col-12">
                <div class="alert alert-light border shadow-sm small text-muted">
                    <strong>Report Note:</strong> This report is a cached snapshot generated at @Model.GeneratedAt.ToString("HH:mm:ss").
                    Data synchronization occurs every 15 minutes. High-volume periods may show slight discrepancies in "Active User" counts.
                </div>
            </div>
        </div>
        <div class="col-lg-9">
            <div class="row">
                <div class="col-md-4">
                    <div class="card shadow-sm border-left-primary">
                        <div class="card-body">
                            <h6 class="text-muted small text-uppercase">Total Users</h6>
                            <h3 class="font-weight-bold">@Model.TotalUsers</h3>
                            <span class="text-success small"><i class="mdi mdi-arrow-up"></i> Live Data</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-left-success">
                        <div class="card-body">
                            <h6 class="text-muted small text-uppercase">Platform Quotes</h6>
                            <h3 class="font-weight-bold">@Model.TotalQuotes</h3>
                            <span class="text-muted small">Across @Model.TotalCategories categories</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm border-left-warning">
                        <div class="card-body">
                            <h6 class="text-muted small text-uppercase">New Users (7d)</h6>
                            <h3 class="font-weight-bold">@Model.RecentSignups</h3>
                            <span class="text-info small">Active: @Model.ActiveUsersLast7Days</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5 class="card-title">User Tier Distribution</h5>
                            <div style="height:300px;">
                                <canvas id="usersChart"></canvas>
                            </div>
                        </div>
                        <div class="col-md-4 border-left">
                            <h5 class="card-title">Data Definitions</h5>
                            <ul class="list-unstyled small mt-3">
                                <li class="mb-2"><strong>Premium:</strong> Users with an active paid subscription.</li>
                                <li class="mb-2"><strong>Active:</strong> Users who favorited or shared a quote in the last 7 days.</li>
                                <li class="mb-2"><strong>Quotes:</strong> Total approved phrases available in the public library.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light"><strong>System Health</strong></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Database</span>
                        <span class="badge bg-success text-white">Online</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Storage (S3)</span>
                        <span class="badge bg-success text-white">94% Free</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="small">API Latency</span>
                        <span class="small text-muted">42ms</span>
                    </div>
                </div>
            </div>

            <div class="card bg-info text-white shadow-sm">
                <div class="card-body">
                    <h6>Need Help?</h6>
                    <p class="small">For technical issues with the reporting engine, contact:</p>
                    <a href="mailto:admin-support@believeinapp.com" class="text-white font-weight-bold small">support@phraseapp.com</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var ctx = document.getElementById('usersChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Premium', 'Free'],
                    datasets: [{
                        data: [@Model.PremiumUsers, @Model.FreeUsers],
                        backgroundColor: ['#28a745', '#e9ecef'],
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        });
    </script>
}