@model Phrase_App.Admin.Controllers.DashboardReportViewModel
@{
    ViewData["Title"] = "Reports Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --amber: #fbbf24;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .export-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--input-bg);
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .export-btn:hover {
            background: var(--orange-light);
            border-color: var(--orange-border);
            color: var(--orange) !important;
        }

    /* ── SNAPSHOT BANNER ── */
    .snapshot-banner {
        background: #f8fafc;
        border: 1px solid var(--input-border);
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        color: var(--muted);
    }

        .snapshot-banner i {
            color: var(--orange);
            font-size: 17px;
            flex-shrink: 0;
        }

        .snapshot-banner strong {
            color: var(--text);
        }

    /* ── STAT CARDS ── */
    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        position: relative;
        overflow: hidden;
        height: 100%;
        transition: transform 0.25s, box-shadow 0.25s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .stat-card.primary {
            background: var(--gradient);
            border: none;
            box-shadow: 0 8px 32px rgba(249,115,22,0.35);
        }

            .stat-card.primary::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 140px;
                height: 140px;
                background: rgba(255,255,255,0.13);
                border-radius: 50%;
            }

        .stat-card.navy {
            background: #1a2235;
            border: 1px solid rgba(251,191,36,0.15);
        }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-label {
        color: rgba(255,255,255,0.75);
    }

    .stat-card.navy .stat-label {
        color: rgba(251,191,36,0.6);
    }

    .stat-value {
        font-size: 38px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1.5px;
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-value {
        color: #fff;
    }

    .stat-card.navy .stat-value {
        color: var(--amber);
    }

    .stat-sub {
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .stat-card.primary .stat-sub {
        color: rgba(255,255,255,0.8);
    }

    .stat-card.navy .stat-sub {
        color: rgba(251,191,36,0.65);
    }

    .stat-icon {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .stat-card.primary .stat-icon {
        background: rgba(255,255,255,0.2);
        color: #fff;
    }

    .stat-card:not(.primary):not(.navy) .stat-icon {
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
    }

    .stat-card.navy .stat-icon {
        background: rgba(251,191,36,0.15);
        color: var(--amber);
    }

    .stat-bar-track {
        height: 5px;
        border-radius: 10px;
        margin-top: 14px;
        overflow: hidden;
    }

    .stat-bar-fill {
        height: 100%;
        border-radius: 10px;
    }

    .stat-card.primary .stat-bar-track {
        background: rgba(255,255,255,0.2);
    }

    .stat-card.primary .stat-bar-fill {
        background: rgba(255,255,255,0.7);
    }

    .stat-card:not(.primary):not(.navy) .stat-bar-track {
        background: #f1f5f9;
    }

    .stat-card:not(.primary):not(.navy) .stat-bar-fill {
        background: var(--gradient);
    }

    .stat-card.navy .stat-bar-track {
        background: rgba(255,255,255,0.08);
    }

    .stat-card.navy .stat-bar-fill {
        background: var(--amber);
    }

    /* ── PANELS ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        margin-bottom: 24px;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .panel-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .panel-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    /* ── CHART DIVIDER ── */
    .chart-divider {
        width: 1px;
        background: #f1f5f9;
        align-self: stretch;
        margin: 0 4px;
    }

    /* ── DATA DEFINITIONS ── */
    .def-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .def-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .def-icon {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

        .def-icon.orange {
            background: var(--orange-light);
            border: 1px solid var(--orange-border);
            color: var(--orange);
        }

        .def-icon.amber {
            background: #fffbeb;
            border: 1px solid #fde68a;
            color: #b45309;
        }

        .def-icon.green {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #16a34a;
        }

    .def-term {
        font-size: 12px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 2px;
    }

    .def-desc {
        font-size: 12px;
        color: var(--muted);
        line-height: 1.5;
    }

    /* ── SYSTEM HEALTH ── */
    .health-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .health-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .health-key {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .health-key i {
            color: var(--orange);
            font-size: 15px;
            width: 18px;
            text-align: center;
        }

    .badge-online {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

        .badge-online::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #16a34a;
            animation: blink 2s infinite;
        }

    .badge-storage {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-latency {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .badge-latency span {
            font-size: 11px;
            color: #16a34a;
            font-weight: 600;
        }

    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── SUPPORT CARD ── */
    .support-card {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 16px;
        padding: 22px;
        border: 1px solid rgba(255,255,255,0.06);
        text-align: center;
    }

    .support-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: rgba(249,115,22,0.15);
        border: 1px solid rgba(249,115,22,0.3);
        color: var(--orange);
        font-size: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
    }

    .support-title {
        font-size: 14px;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 6px;
    }

    .support-desc {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 14px;
        line-height: 1.6;
    }

    .support-link {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--gradient);
        color: #fff !important;
        border-radius: 10px;
        padding: 9px 18px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none !important;
        box-shadow: 0 4px 14px rgba(249,115,22,0.35);
        transition: opacity 0.2s;
    }

        .support-link:hover {
            opacity: 0.88;
        }

    /* ── PRINT ── */
    @@media print {
        .export-btn, .sidebar, .navbar {
            display: none !important;
        }

        .container-fluid {
            padding: 0 !important;
        }

        .col-lg-9, .col-lg-3 {
            width: 100% !important;
            flex: 0 0 100% !important;
            max-width: 100% !important;
        }

        .panel {
            break-inside: avoid;
        }
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>Analytics & Insights</h2>
        <p>Comprehensive platform overview and system status</p>
    </div>
    <button class="export-btn" onclick="window.print()">
        <i class="mdi mdi-printer-outline"></i> Export PDF
    </button>
</div>

<!-- Snapshot Banner -->
<div class="snapshot-banner">
    <i class="mdi mdi-information-outline"></i>
    <span>
        <strong>Cached Snapshot</strong> — Generated at
        <strong>@Model.GeneratedAt.ToString("MMM dd, yyyy · HH:mm:ss UTC")</strong>.
        Data synchronization occurs every 15 minutes.
    </span>
</div>

<div class="row g-4">

    <!-- Main Column -->
    <div class="col-lg-9">

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">

            <div class="col-md-4">
                <div class="stat-card primary">
                    <div class="stat-icon"><i class="mdi mdi-account"></i></div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value">@Model.TotalUsers</div>
                    <div class="stat-sub">
                        <i class="mdi mdi-circle" style="font-size:8px; color:rgba(255,255,255,0.9);"></i>
                        Live data
                    </div>
                    <div class="stat-bar-track">
                        <div class="stat-bar-fill" style="width:100%;"></div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon"><i class="mdi mdi-format-quote"></i></div>
                    <div class="stat-label">Platform Affirmations</div>
                    <div class="stat-value">@Model.TotalQuotes</div>
                    <div class="stat-sub">
                        <i class="mdi mdi-tag-multiple-outline"></i>
                        Across @Model.TotalCategories categories
                    </div>
                    <div class="stat-bar-track">
                        <div class="stat-bar-fill" style="width:75%;"></div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="stat-card navy">
                    <div class="stat-icon"><i class="mdi mdi-account-plus"></i></div>
                    <div class="stat-label">New Users — 7 Days</div>
                    <div class="stat-value">@Model.RecentSignups</div>
                    <div class="stat-sub">
                        <i class="mdi mdi-check-circle-outline"></i>
                        @Model.ActiveUsersLast7Days active this week
                    </div>
                    <div class="stat-bar-track">
                        <div class="stat-bar-fill" style="width:60%;"></div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Chart + Definitions -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-chart-donut"></i>
                User Tier Distribution
            </div>
            <div class="row g-0">

                <div class="col-md-7">
                    <div style="height:280px;">
                        <canvas id="usersChart"></canvas>
                    </div>
                </div>

                <div class="col-auto d-none d-md-block">
                    <div class="chart-divider"></div>
                </div>

                <div class="col-md-4 ps-md-4 pt-3 pt-md-0">
                    <div style="font-size:12px; font-weight:700; color:var(--muted); letter-spacing:0.8px; text-transform:uppercase; margin-bottom:14px;">
                        Data Definitions
                    </div>

                    <div class="def-row">
                        <div class="def-icon orange"><i class="mdi mdi-crown"></i></div>
                        <div>
                            <div class="def-term">Premium</div>
                            <div class="def-desc">Users with an active paid subscription.</div>
                        </div>
                    </div>

                    <div class="def-row">
                        <div class="def-icon green"><i class="mdi mdi-account-check"></i></div>
                        <div>
                            <div class="def-term">Active</div>
                            <div class="def-desc">Users who favorited or shared a quote in the last 7 days.</div>
                        </div>
                    </div>

                    <div class="def-row">
                        <div class="def-icon amber"><i class="mdi mdi-format-quote"></i></div>
                        <div>
                            <div class="def-term">Affirmations</div>
                            <div class="def-desc">Total approved phrases in the public library.</div>
                        </div>
                    </div>

                    <!-- Mini stats -->
                    <div style="margin-top:18px; display:flex; gap:10px;">
                        <div style="flex:1; background:var(--orange-light); border:1px solid var(--orange-border); border-radius:12px; padding:12px; text-align:center;">
                            <div style="font-size:18px; font-weight:800; color:var(--orange);">@Model.PremiumUsers</div>
                            <div style="font-size:11px; font-weight:600; color:#c2410c;">Premium</div>
                        </div>
                        <div style="flex:1; background:#f8fafc; border:1px solid var(--input-border); border-radius:12px; padding:12px; text-align:center;">
                            <div style="font-size:18px; font-weight:800; color:var(--text);">@Model.FreeUsers</div>
                            <div style="font-size:11px; font-weight:600; color:var(--muted);">Free</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <!-- Right Sidebar -->
    <div class="col-lg-3">

        <!-- System Health -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-server-network"></i>
                System Health
            </div>

            <div class="health-row">
                <span class="health-key"><i class="mdi mdi-database"></i> Database</span>
                <span class="badge-online">Online</span>
            </div>

            <div class="health-row">
                <span class="health-key"><i class="mdi mdi-cloud"></i> Storage (S3)</span>
                <span class="badge-storage">94% Free</span>
            </div>

            <div class="health-row">
                <span class="health-key"><i class="mdi mdi-spotlight"></i> API Latency</span>
                <span class="badge-latency">42ms <span>● Fast</span></span>
            </div>

        </div>

        <!-- Support Card -->
        <div class="support-card">
            <div class="support-icon">
                <i class="mdi mdi-help-circle-outline"></i>
            </div>
            <div class="support-title">Need Help?</div>
            <div class="support-desc">
                For technical issues with the reporting engine, reach out to the support team.
            </div>
            <a href="mailto:getbelievein@gmail.com" class="support-link">
                <i class="mdi mdi-email-outline"></i>
                getbelievein@gmail.com
            </a>
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var ctx = document.getElementById('usersChart').getContext('2d');

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Premium', 'Free'],
                    datasets: [{
                        data: [@Model.PremiumUsers, @Model.FreeUsers],
                        backgroundColor: ['#f97316', '#f1f5f9'],
                        borderColor:     ['#fff4ed',  '#e2e8f0'],
                        borderWidth: 3,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: { duration: 600 },
                    cutout: '68%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                color: '#64748b',
                                font: { size: 12, weight: '600' },
                                usePointStyle: true,
                                pointStyleWidth: 10
                            }
                        },
                        tooltip: {
                            backgroundColor: '#1a2235',
                            borderColor: 'rgba(249,115,22,0.3)',
                            borderWidth: 1,
                            titleColor: '#f1f5f9',
                            bodyColor: '#94a3b8',
                            padding: 12,
                            cornerRadius: 10
                        }
                    }
                }
            });
        });
    </script>
}