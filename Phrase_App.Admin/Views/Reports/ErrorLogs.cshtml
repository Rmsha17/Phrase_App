@model Phrase_App.Admin.Controllers.ErrorLogsViewModel

@{
    ViewData["Title"] = "Error Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --amber: #fbbf24;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
        --red: #dc2626;
        --red-light: #fff5f5;
        --red-border: #fecaca;
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .refresh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--input-bg);
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .refresh-btn:hover {
            background: var(--orange-light);
            border-color: var(--orange-border);
            color: var(--orange) !important;
        }

    /* ── PANELS ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        margin-bottom: 24px;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .panel-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .panel-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    /* ── ERROR TYPE LIST ── */
    .error-type-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
        gap: 10px;
    }

        .error-type-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .error-type-name {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 8px;
        overflow: hidden;
    }

    .error-type-icon {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        flex-shrink: 0;
        background: var(--red-light);
        border: 1px solid var(--red-border);
        color: var(--red);
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-type-label {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 180px;
    }

    .error-count-badge {
        display: inline-flex;
        align-items: center;
        background: var(--red-light);
        color: var(--red);
        border: 1px solid var(--red-border);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }

    /* ── DATATABLE ── */
    .dataTables_filter input {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 10px !important;
        padding: 7px 14px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        outline: none !important;
        margin-left: 8px !important;
    }

        .dataTables_filter input:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.1) !important;
        }

    .dataTables_filter label,
    .dataTables_length label {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
    }

    .dataTables_length select {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 8px !important;
        padding: 5px 10px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        margin: 0 6px !important;
    }

    .dataTables_info {
        font-size: 13px;
        color: var(--muted);
        padding-top: 10px !important;
    }

    /* ── TABLE ── */
    table.dataTable {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: 100% !important;
    }

        table.dataTable thead th {
            font-size: 11px !important;
            font-weight: 700 !important;
            letter-spacing: 1px !important;
            text-transform: uppercase !important;
            color: var(--muted) !important;
            border: none !important;
            border-bottom: 2px solid #e2e8f0 !important;
            padding: 14px 16px !important;
            background: #f8fafc !important;
            white-space: nowrap;
        }

        table.dataTable tbody tr {
            transition: background 0.15s;
        }

            table.dataTable tbody tr:hover {
                background: #fff9f5 !important;
            }

        table.dataTable tbody td {
            font-size: 13px !important;
            color: var(--text) !important;
            border: none !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 13px 16px !important;
            vertical-align: middle !important;
        }

        table.dataTable.table-striped tbody tr:nth-of-type(odd) {
            background: transparent !important;
        }

    /* ── TABLE CELLS ── */
    .time-cell strong {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
    }

    .time-cell span {
        font-size: 11px;
        color: var(--muted-light);
        display: block;
        margin-top: 2px;
    }

    .platform-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: var(--muted);
        border: 1px solid var(--input-border);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .error-type-code {
        display: inline-block;
        background: var(--red-light);
        color: var(--red);
        border: 1px solid var(--red-border);
        border-radius: 8px;
        padding: 3px 10px;
        font-size: 11.5px;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .msg-cell {
        font-size: 12.5px;
        color: var(--muted);
        max-width: 280px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .btn-view-log {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--red-light);
        color: var(--red) !important;
        border: 1px solid var(--red-border);
        border-radius: 9px;
        padding: 6px 13px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-view-log:hover {
            background: #fee2e2;
            border-color: #fca5a5;
        }

    /* ── PAGINATION ── */
    .dataTables_paginate .paginate_button {
        border-radius: 9px !important;
        border: 1px solid #e2e8f0 !important;
        background: #fff !important;
        color: var(--muted) !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        margin: 0 2px !important;
        padding: 6px 12px !important;
        transition: all 0.2s !important;
    }

        .dataTables_paginate .paginate_button:hover {
            background: var(--orange-light) !important;
            border-color: var(--orange-border) !important;
            color: var(--orange) !important;
        }

        .dataTables_paginate .paginate_button.current,
        .dataTables_paginate .paginate_button.current:hover {
            background: var(--gradient) !important;
            border-color: transparent !important;
            color: #fff !important;
            box-shadow: 0 3px 10px rgba(249,115,22,0.3) !important;
        }

        .dataTables_paginate .paginate_button.disabled,
        .dataTables_paginate .paginate_button.disabled:hover {
            opacity: 0.4 !important;
            cursor: default !important;
        }

    /* ── MODAL ── */
    #errorModal {
        z-index: 100050 !important;
    }

    .modal-backdrop {
        z-index: 100040 !important;
    }

    .modal-content {
        border: none !important;
        border-radius: 20px !important;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.18) !important;
    }

    .modal-header-custom {
        background: #1a2235;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .modal-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .modal-header-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(220,38,38,0.15);
        border: 1px solid rgba(220,38,38,0.3);
        color: #f87171;
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-header-title {
        font-size: 16px;
        font-weight: 700;
        color: #f1f5f9;
        margin: 0 0 2px;
    }

    .modal-header-sub {
        font-size: 12px;
        color: #64748b;
    }

    .modal-close-btn {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.1);
        color: #94a3b8;
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.2s;
        line-height: 1;
    }

        .modal-close-btn:hover {
            background: rgba(255,255,255,0.14);
            color: #f1f5f9;
        }

    .modal-body-custom {
        background: #fff;
        padding: 24px;
    }

    .modal-meta-row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .modal-meta-tile {
        flex: 1;
        min-width: 140px;
        background: var(--input-bg);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        padding: 14px 16px;
    }

    .modal-meta-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 6px;
    }

    .modal-meta-val {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .modal-log-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .modal-log-title i {
            color: var(--orange);
        }

    .modal-log-box {
        background: #1a2235;
        border-radius: 14px;
        padding: 18px 20px;
        border: 1px solid rgba(255,255,255,0.06);
    }

        .modal-log-box pre {
            color: #4ade80;
            font-size: 12px;
            font-family: 'Courier New', monospace;
            white-space: pre-wrap;
            word-break: break-all;
            margin: 0;
            line-height: 1.7;
        }

    .modal-footer-custom {
        background: #f8fafc;
        border-top: 1px solid var(--input-border);
        padding: 16px 24px;
        display: flex;
        justify-content: flex-end;
    }

    .btn-modal-close {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #f1f5f9;
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 10px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-modal-close:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }
</style>

<!-- Toast Container -->
<div id="toastContainer" style="position:fixed; top:24px; right:24px; z-index:9999;"></div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>System Error Logs</h2>
        <p>
            <i class="mdi mdi-clock-outline" style="font-size:13px;"></i>
            Generated at: <strong>@Model.GeneratedAt.ToString("MMM dd, yyyy · HH:mm UTC")</strong>
        </p>
    </div>
    <button class="refresh-btn" onclick="location.reload()">
        <i class="mdi mdi-refresh"></i> Refresh
    </button>
</div>

<div class="row g-4 mb-0">

    <!-- Errors by Type -->
    <div class="col-lg-4">
        <div class="panel" style="height:calc(100% - 24px);">
            <div class="panel-title">
                <i class="mdi mdi-alert-circle-outline"></i>
                Errors by Type
            </div>

            @if (Model.ErrorsByType != null)
            {
                foreach (var s in Model.ErrorsByType.Take(6))
                {
                    <div class="error-type-row">
                        <div class="error-type-name">
                            <div class="error-type-icon">
                                <i class="mdi mdi-bug-outline"></i>
                            </div>
                            <span class="error-type-label" title="@s.ErrorType">@s.ErrorType</span>
                        </div>
                        <span class="error-count-badge">@s.Count</span>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center; padding:32px 0; color:var(--muted-light); font-size:13px;">
                    <i class="mdi mdi-check-circle-outline" style="font-size:32px; color:#16a34a; display:block; margin-bottom:8px;"></i>
                    No errors recorded
                </div>
            }
        </div>
    </div>

    <!-- Platform Distribution Chart -->
    <div class="col-lg-8">
        <div class="panel" style="height:calc(100% - 24px);">
            <div class="panel-title">
                <i class="mdi mdi-monitor-cellphone"></i>
                Platform Distribution
            </div>
            <div style="height:220px; position:relative;">
                <canvas id="platformChart"></canvas>
            </div>
        </div>
    </div>

</div>

<!-- Logs Table -->
<div class="panel">
    <div class="panel-title">
        <i class="mdi mdi-table-search"></i>
        Error Log Entries
    </div>
    <div class="table-responsive">
        <table id="errorsTable" class="table" style="width:100%">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Platform</th>
                    <th>Type</th>
                    <th>Message</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ErrorLogs != null)
                {
                    foreach (var e in Model.ErrorLogs)
                    {
                        <tr>
                            <td>
                                <div class="time-cell">
                                    <strong>@e.Timestamp.ToString("MMM dd, yyyy")</strong>
                                    <span>@e.Timestamp.ToString("HH:mm:ss")</span>
                                </div>
                            </td>
                            <td>
                                <span class="platform-badge">
                                    <i class="mdi mdi-monitor-outline" style="font-size:11px;"></i>
                                    @e.Platform
                                </span>
                            </td>
                            <td>
                                <span class="error-type-code" title="@e.ErrorType">@e.ErrorType</span>
                            </td>
                            <td>
                                <div class="msg-cell" title="@e.Message">@e.Message</div>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn-view-log"
                                        onclick="openLogModal(this)"
                                        data-time="@e.Timestamp.ToString("MMM dd, yyyy · HH:mm:ss")"
                                        data-plat="@e.Platform"
                                        data-type="@e.ErrorType">
                                    <i class="mdi mdi-eye-outline"></i> View
                                </button>
                                <div class="d-none full-message-content">@e.Message</div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Error Detail Modal -->
<div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header-custom">
                <div class="modal-header-left">
                    <div class="modal-header-icon">
                        <i class="mdi mdi-bug-outline"></i>
                    </div>
                    <div>
                        <div class="modal-header-title">Error Details</div>
                        <div class="modal-header-sub">Full exception information</div>
                    </div>
                </div>
                <button class="modal-close-btn" onclick="$('#errorModal').modal('hide')">
                    &times;
                </button>
            </div>

            <div class="modal-body-custom">
                <div class="modal-meta-row">
                    <div class="modal-meta-tile">
                        <div class="modal-meta-label"><i class="mdi mdi-clock-outline"></i> Timestamp</div>
                        <div class="modal-meta-val" id="mTime">—</div>
                    </div>
                    <div class="modal-meta-tile">
                        <div class="modal-meta-label"><i class="mdi mdi-monitor-outline"></i> Platform</div>
                        <div class="modal-meta-val" id="mPlat">—</div>
                    </div>
                    <div class="modal-meta-tile">
                        <div class="modal-meta-label"><i class="mdi mdi-bug-outline"></i> Type</div>
                        <div class="modal-meta-val" id="mType" style="color:var(--red); font-family:'Courier New',monospace; font-size:12px;">—</div>
                    </div>
                </div>

                <div class="modal-log-title">
                    <i class="mdi mdi-console"></i> Full Exception
                </div>
                <div class="modal-log-box">
                    <pre id="mMsg"></pre>
                </div>
            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-modal-close" onclick="$('#errorModal').modal('hide')">
                    <i class="mdi mdi-close"></i> Close
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/Admin/assets/extra-libs/DataTables/datatables.min.js"></script>

    <script>
        // ── Chart ──
        document.addEventListener("DOMContentLoaded", function () {
            try {
                var labels = [], data = [];

                @if (Model.ErrorsByPlatform != null)
                {
                        foreach (var item in Model.ErrorsByPlatform)
                        {
                                <text>
                                labels.push("@Html.Raw(item.Platform)");
                                data.push(@item.Count);
                                </text>
                        }
                }

                var ctx = document.getElementById('platformChart');
                if (ctx && labels.length > 0) {
                    var barColors = labels.map(function(_, i) {
                        var palette = ['#f97316','#fb923c','#fdba74','#fbbf24','#fcd34d'];
                        return palette[i % palette.length];
                    });

                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'Errors',
                                data: data,
                                backgroundColor: barColors,
                                borderRadius: 8,
                                borderSkipped: false
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#1a2235',
                                    borderColor: 'rgba(249,115,22,0.3)',
                                    borderWidth: 1,
                                    titleColor: '#f1f5f9',
                                    bodyColor: '#94a3b8',
                                    padding: 12,
                                    cornerRadius: 10
                                }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: { precision: 0, color: '#94a3b8', font: { size: 11 } },
                                    grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false }
                                },
                                y: {
                                    grid: { display: false },
                                    ticks: { color: '#64748b', font: { size: 12 } }
                                }
                            }
                        }
                    });
                }
            } catch (err) {
                console.error("Chart error:", err);
            }
        });

        // ── DataTable ──
        $(document).ready(function () {
            if ($.fn.DataTable) {
                var table = $('#errorsTable').DataTable({
                    order: [[0, 'desc']],
                    pageLength: 15,
                    dom:
                        '<"row mb-3 align-items-center"<"col-sm-6"l><"col-sm-6 text-end"f>>' +
                        't' +
                        '<"row mt-3 align-items-center"<"col-sm-6"i><"col-sm-6 text-end"p>>'
                });

                function alignControls() {
                    var $wrap = $('#errorsTable').closest('.dataTables_wrapper');
                    $wrap.find('.dataTables_length').css('text-align', 'left');
                    $wrap.find('.dataTables_info').css('text-align', 'left');
                    $wrap.find('.dataTables_filter').css('text-align', 'right');
                    $wrap.find('.dataTables_paginate').css('text-align', 'right');
                }

                alignControls();
                table.on('draw.dt', function () { alignControls(); });
            }
        });

        // ── Modal ──
        function openLogModal(btnElement) {
            try {
                var btn  = $(btnElement);
                var time = btn.data('time');
                var plat = btn.data('plat');
                var type = btn.data('type');
                var msg  = btn.siblings('.full-message-content').text();

                $('#mTime').text(time);
                $('#mPlat').text(plat);
                $('#mType').text(type);
                $('#mMsg').text(msg);

                $('#errorModal').modal('show');
            } catch (err) {
                console.error("Modal error:", err);
            }
        }
    </script>
}