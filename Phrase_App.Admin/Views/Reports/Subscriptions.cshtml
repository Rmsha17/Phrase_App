@model Phrase_App.Admin.Controllers.SubscriptionReportViewModel

@{
    ViewData["Title"] = "Subscription Analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var mrr = (Model.MonthlySubscribers * 4.99 + (Model.YearlySubscribers * 39.99 / 12));
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --amber: #fbbf24;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .refresh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--input-bg);
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .refresh-btn:hover {
            background: var(--orange-light);
            border-color: var(--orange-border);
            color: var(--orange) !important;
        }

    /* ── STAT CARDS ── */
    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        position: relative;
        overflow: hidden;
        height: 100%;
        transition: transform 0.25s, box-shadow 0.25s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .stat-card.primary {
            background: var(--gradient);
            border: none;
            box-shadow: 0 8px 32px rgba(249,115,22,0.35);
        }

            .stat-card.primary::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 140px;
                height: 140px;
                background: rgba(255,255,255,0.13);
                border-radius: 50%;
            }

        .stat-card.navy {
            background: #1a2235;
            border: 1px solid rgba(251,191,36,0.15);
        }

        .stat-card.warn {
            background: #fffbeb;
            border: 1.5px solid #fde68a;
        }

        .stat-card.danger {
            background: #fff5f5;
            border: 1.5px solid #fecaca;
        }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-label {
        color: rgba(255,255,255,0.75);
    }

    .stat-card.navy .stat-label {
        color: rgba(251,191,36,0.6);
    }

    .stat-card.warn .stat-label {
        color: #b45309;
    }

    .stat-card.danger .stat-label {
        color: #dc2626;
    }

    .stat-value {
        font-size: 38px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1.5px;
        margin-bottom: 10px;
    }

    .stat-card.primary .stat-value {
        color: #fff;
    }

    .stat-card.navy .stat-value {
        color: var(--amber);
    }

    .stat-card.warn .stat-value {
        color: #b45309;
    }

    .stat-card.danger .stat-value {
        color: #dc2626;
    }

    .stat-sub {
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .stat-card.primary .stat-sub {
        color: rgba(255,255,255,0.8);
    }

    .stat-card.navy .stat-sub {
        color: rgba(251,191,36,0.65);
    }

    .stat-card.warn .stat-sub {
        color: #b45309;
        opacity: 0.75;
    }

    .stat-card.danger .stat-sub {
        color: #dc2626;
        opacity: 0.75;
    }

    .stat-icon {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .stat-card.primary .stat-icon {
        background: rgba(255,255,255,0.2);
        color: #fff;
    }

    .stat-card.navy .stat-icon {
        background: rgba(251,191,36,0.15);
        color: var(--amber);
    }

    .stat-card.warn .stat-icon {
        background: rgba(251,191,36,0.15);
        color: #b45309;
        border: 1px solid #fde68a;
    }

    .stat-card.danger .stat-icon {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .stat-bar-track {
        height: 5px;
        border-radius: 10px;
        margin-top: 14px;
        overflow: hidden;
    }

    .stat-bar-fill {
        height: 100%;
        border-radius: 10px;
    }

    .stat-card.primary .stat-bar-track {
        background: rgba(255,255,255,0.2);
    }

    .stat-card.primary .stat-bar-fill {
        background: rgba(255,255,255,0.7);
    }

    .stat-card.navy .stat-bar-track {
        background: rgba(255,255,255,0.08);
    }

    .stat-card.navy .stat-bar-fill {
        background: var(--amber);
    }

    .stat-card.warn .stat-bar-track {
        background: #fde68a;
    }

    .stat-card.warn .stat-bar-fill {
        background: #f59e0b;
    }

    .stat-card.danger .stat-bar-track {
        background: #fecaca;
    }

    .stat-card.danger .stat-bar-fill {
        background: #ef4444;
    }

    /* ── PANELS ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        margin-bottom: 24px;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .panel-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .panel-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    /* ── EXPIRING TABLE ── */
    .dataTables_filter input {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 10px !important;
        padding: 7px 14px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        outline: none !important;
        margin-left: 8px !important;
    }

        .dataTables_filter input:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.1) !important;
        }

    .dataTables_filter label,
    .dataTables_length label {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
    }

    .dataTables_length select {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 8px !important;
        padding: 5px 10px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        margin: 0 6px !important;
    }

    .dataTables_info {
        font-size: 13px;
        color: var(--muted);
        padding-top: 10px !important;
    }

    table.dataTable {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: 100% !important;
    }

        table.dataTable thead th {
            font-size: 11px !important;
            font-weight: 700 !important;
            letter-spacing: 1px !important;
            text-transform: uppercase !important;
            color: var(--muted) !important;
            border: none !important;
            border-bottom: 2px solid #e2e8f0 !important;
            padding: 14px 16px !important;
            background: #f8fafc !important;
            white-space: nowrap;
        }

        table.dataTable tbody tr {
            transition: background 0.15s;
        }

            table.dataTable tbody tr:hover {
                background: #fff9f5 !important;
            }

        table.dataTable tbody td {
            font-size: 13px !important;
            color: var(--text) !important;
            border: none !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 13px 16px !important;
            vertical-align: middle !important;
        }

        table.dataTable.table-striped tbody tr:nth-of-type(odd) {
            background: transparent !important;
        }

    /* ── TABLE CELLS ── */
    .email-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .email-avatar {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        flex-shrink: 0;
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        color: var(--orange);
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sub-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .expiry-date {
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        font-family: 'Courier New', monospace;
    }

    .status-urgent {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff5f5;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .status-normal {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    /* ── PAGINATION ── */
    .dataTables_paginate .paginate_button {
        border-radius: 9px !important;
        border: 1px solid #e2e8f0 !important;
        background: #fff !important;
        color: var(--muted) !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        margin: 0 2px !important;
        padding: 6px 12px !important;
        transition: all 0.2s !important;
    }

        .dataTables_paginate .paginate_button:hover {
            background: var(--orange-light) !important;
            border-color: var(--orange-border) !important;
            color: var(--orange) !important;
        }

        .dataTables_paginate .paginate_button.current,
        .dataTables_paginate .paginate_button.current:hover {
            background: var(--gradient) !important;
            border-color: transparent !important;
            color: #fff !important;
            box-shadow: 0 3px 10px rgba(249,115,22,0.3) !important;
        }

        .dataTables_paginate .paginate_button.disabled,
        .dataTables_paginate .paginate_button.disabled:hover {
            opacity: 0.4 !important;
            cursor: default !important;
        }

    /* ── PLAN ECONOMICS ── */
    .economics-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .economics-row:last-child {
            border-bottom: none;
        }

    .economics-key {
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .economics-key i {
            color: var(--orange);
        }

    .economics-val {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
    }

    /* ── MRR BOX ── */
    .mrr-box {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 16px;
        padding: 20px 22px;
        margin-top: 16px;
        border: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .mrr-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        flex-shrink: 0;
        background: rgba(249,115,22,0.15);
        border: 1px solid rgba(249,115,22,0.3);
        color: var(--orange);
        font-size: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mrr-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 4px;
    }

    .mrr-value {
        font-size: 26px;
        font-weight: 800;
        color: var(--amber);
        letter-spacing: -0.5px;
        line-height: 1;
    }

    .mrr-sub {
        font-size: 11px;
        color: #475569;
        margin-top: 3px;
    }

    /* ── RETENTION CARD ── */
    .retention-card {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 16px;
        padding: 22px;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .retention-title {
        font-size: 14px;
        font-weight: 700;
        color: #f1f5f9;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .retention-title i {
            color: var(--orange);
        }

    .retention-desc {
        font-size: 12px;
        color: #64748b;
        line-height: 1.65;
        margin-bottom: 16px;
    }

    .retention-check {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #94a3b8;
        font-weight: 500;
        padding: 5px 0;
    }

        .retention-check i {
            color: #16a34a;
            font-size: 15px;
        }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>Subscription Analytics</h2>
        <p>Plan distribution, expiries and revenue overview</p>
    </div>
    <button class="refresh-btn" onclick="location.reload()">
        <i class="mdi mdi-refresh"></i> Refresh Report
    </button>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">

    <div class="col-lg-3 col-md-6">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="mdi mdi-calendar"></i></div>
            <div class="stat-label">Monthly Plan</div>
            <div class="stat-value">@Model.MonthlySubscribers</div>
            <div class="stat-sub">
                <i class="mdi mdi-account"></i> Active subscribers
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:100%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card navy">
            <div class="stat-icon"><i class="mdi mdi-calendar-check"></i></div>
            <div class="stat-label">Yearly Plan</div>
            <div class="stat-value">@Model.YearlySubscribers</div>
            <div class="stat-sub">
                <i class="mdi mdi-shield"></i> Annual subscribers
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:80%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card warn">
            <div class="stat-icon"><i class="mdi mdi-clock-alert"></i></div>
            <div class="stat-label">Expiring — 30 Days</div>
            <div class="stat-value">@Model.ExpiringWithin30Days</div>
            <div class="stat-sub">
                <i class="mdi mdi-alert"></i> Need attention
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:60%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card danger">
            <div class="stat-icon"><i class="mdi mdi-calendar-remove"></i></div>
            <div class="stat-label">Expired Total</div>
            <div class="stat-value">@Model.ExpiredSubscriptions</div>
            <div class="stat-sub">
                <i class="mdi mdi-close-circle"></i> Lapsed subscriptions
            </div>
            <div class="stat-bar-track">
                <div class="stat-bar-fill" style="width:40%;"></div>
            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    <!-- Left: Chart + Table -->
    <div class="col-lg-8">

        <!-- Doughnut Chart -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-chart-donut"></i>
                Subscription Mix
            </div>
            <div id="chartContainer" style="height:260px; position:relative;">
                <canvas id="subscriptionPieChart"></canvas>
            </div>
        </div>

        <!-- Expiring Users Table -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-account-clock"></i>
                Expiring Users
            </div>
            <div class="table-responsive">
                <table id="expiringTable" class="table" style="width:100%">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Type</th>
                            <th>Expiry Date</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.ExpiringUsers)
                        {
                            var daysLeft = (u.ExpiryDate.Date - DateTime.UtcNow.Date).Days;
                            var initial = string.IsNullOrEmpty(u.UserEmail) ? "?" : u.UserEmail.Substring(0, 1).ToUpper();

                            <tr>
                                <td>
                                    <div class="email-cell">
                                        <div class="email-avatar">@initial</div>
                                        <span style="font-size:13px; font-weight:500;">@u.UserEmail</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="sub-type-badge">
                                        <i class="mdi mdi-crown" style="font-size:10px;"></i>
                                        @u.SubscriptionType
                                    </span>
                                </td>
                                <td>
                                    <span class="expiry-date">@u.ExpiryDate.ToString("MMM dd, yyyy")</span>
                                </td>
                                <td class="text-center">
                                    @if (daysLeft <= 1)
                                    {
                                        <span class="status-urgent">
                                            <i class="mdi mdi-alert-circle-outline" style="font-size:11px;"></i>
                                            Action Needed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-normal">
                                            <i class="mdi mdi-check-circle-outline" style="font-size:11px;"></i>
                                            Normal
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Right: Economics + Retention -->
    <div class="col-lg-4">

        <!-- Plan Economics -->
        <div class="panel" style="margin-bottom:20px;">
            <div class="panel-title">
                <i class="mdi mdi-currency-usd"></i>
                Plan Economics
            </div>

            <div class="economics-row">
                <span class="economics-key"><i class="mdi mdi-calendar"></i> Monthly Price</span>
                <span class="economics-val">$4.99</span>
            </div>
            <div class="economics-row">
                <span class="economics-key"><i class="mdi mdi-calendar-check"></i> Yearly Price</span>
                <span class="economics-val">$29.99</span>
            </div>
            <div class="economics-row">
                <span class="economics-key"><i class="mdi mdi-package"></i> Monthly Subs</span>
                <span class="economics-val">@Model.MonthlySubscribers</span>
            </div>
            <div class="economics-row">
                <span class="economics-key"><i class="mdi mdi-account-star"></i> Yearly Subs</span>
                <span class="economics-val">@Model.YearlySubscribers</span>
            </div>

            <!-- MRR Box -->
            <div class="mrr-box">
                <div class="mrr-icon">
                    <i class="mdi mdi-trending-up"></i>
                </div>
                <div>
                    <div class="mrr-label">Estimated MRR</div>
                    <div class="mrr-value">$@mrr.ToString("F2")</div>
                    <div class="mrr-sub">Monthly Recurring Revenue</div>
                </div>
            </div>
        </div>

        <!-- Retention Insights -->
        <div class="retention-card">
            <div class="retention-title">
                <i class="mdi mdi-shield-outline"></i>
                Retention Insights
            </div>
            <div class="retention-desc">
                Yearly subscribers show <strong style="color:#f1f5f9;">40% higher retention rates</strong>
                in BelieveIn compared to monthly users.
            </div>
            <div class="retention-check">
                <i class="mdi mdi-check-circle"></i> Standardized billing
            </div>
            <div class="retention-check">
                <i class="mdi mdi-check-circle"></i> Auto-renewal enabled
            </div>
            <div class="retention-check">
                <i class="mdi mdi-check-circle"></i> Google Play RTDN active
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/Admin/assets/extra-libs/DataTables/datatables.min.js"></script>

    <script>
        (function () {

            // ── Doughnut Chart ──
            function initChart() {
                if (typeof Chart === 'undefined') { setTimeout(initChart, 100); return; }

                var ctx = document.getElementById('subscriptionPieChart');
                if (!ctx) return;

                var mCount = parseInt("@Model.MonthlySubscribers") || 0;
                var yCount = parseInt("@Model.YearlySubscribers")  || 0;

                if (mCount === 0 && yCount === 0) {
                    document.getElementById('chartContainer').innerHTML =
                        '<div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:13px;color:#94a3b8;">No subscription data available</div>';
                    return;
                }

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Monthly', 'Yearly'],
                        datasets: [{
                            data: [mCount, yCount],
                            backgroundColor: ['#f97316', '#1a2235'],
                            borderColor:     ['#fff4ed', '#263044'],
                            borderWidth: 3,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '72%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 20,
                                    color: '#64748b',
                                    font: { size: 12, weight: '600' },
                                    usePointStyle: true,
                                    pointStyleWidth: 10
                                }
                            },
                            tooltip: {
                                backgroundColor: '#1a2235',
                                borderColor: 'rgba(249,115,22,0.3)',
                                borderWidth: 1,
                                titleColor: '#f1f5f9',
                                bodyColor: '#94a3b8',
                                padding: 12,
                                cornerRadius: 10
                            }
                        }
                    }
                });
            }

            if (document.readyState === 'complete') { initChart(); }
            else { window.addEventListener('load', initChart); }

            // ── DataTable ──
            $(document).ready(function () {
                if ($.fn.DataTable) {
                    var table = $('#expiringTable').DataTable({
                        pageLength: 5,
                        order: [[2, 'asc']],
                        dom:
                            '<"row mb-3 align-items-center"<"col-sm-6"l><"col-sm-6 text-end"f>>' +
                            't' +
                            '<"row mt-3 align-items-center"<"col-sm-6"i><"col-sm-6 text-end"p>>'
                    });

                    function alignControls() {
                        var $wrap = $('#expiringTable').closest('.dataTables_wrapper');
                        $wrap.find('.dataTables_length').css('text-align', 'left');
                        $wrap.find('.dataTables_info').css('text-align',  'left');
                        $wrap.find('.dataTables_filter').css('text-align', 'right');
                        $wrap.find('.dataTables_paginate').css('text-align', 'right');
                    }

                    alignControls();
                    table.on('draw.dt', function () { alignControls(); });
                }
            });

        })();
    </script>
}