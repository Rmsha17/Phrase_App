@{
    Layout = null;
    bool success = ViewBag.Success ?? false;
    string title = ViewBag.Title ?? (success ? "Email Confirmed!" : "Confirmation Failed");
    string message = ViewBag.Message ?? (success
        ? "Your account is now active and ready to go. Return to the BelieveIn app to start your journey."
        : "Something went wrong. Please try again or request a new confirmation link from the app.");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BelieveIn | @title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@mdi/font@7.2.96/css/materialdesignicons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0f1623;
            overflow: hidden;
            position: relative;
        }

        /* ── BACKGROUND ── */
        .bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
        }

        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.5;
            animation: drift 20s ease-in-out infinite alternate;
        }

            .bg-orb.o1 {
                width: 480px;
                height: 480px;
                top: -140px;
                left: -140px;
                animation-duration: 22s;
            }

            .bg-orb.o2 {
                width: 360px;
                height: 360px;
                bottom: -80px;
                right: -80px;
                animation-duration: 28s;
                animation-direction: alternate-reverse;
            }

            .bg-orb.o3 {
                width: 260px;
                height: 260px;
                top: 55%;
                left: 65%;
                animation-duration: 16s;
            }

        /* Success orb colors */
        .state-success .bg-orb.o1 {
            background: radial-gradient(circle, rgba(249,115,22,0.45), transparent 70%);
        }

        .state-success .bg-orb.o2 {
            background: radial-gradient(circle, rgba(34,197,94,0.2), transparent 70%);
        }

        .state-success .bg-orb.o3 {
            background: radial-gradient(circle, rgba(251,191,36,0.2), transparent 70%);
        }

        /* Error orb colors */
        .state-error .bg-orb.o1 {
            background: radial-gradient(circle, rgba(239,68,68,0.4), transparent 70%);
        }

        .state-error .bg-orb.o2 {
            background: radial-gradient(circle, rgba(249,115,22,0.2), transparent 70%);
        }

        .state-error .bg-orb.o3 {
            background: radial-gradient(circle, rgba(251,191,36,0.15), transparent 70%);
        }

        @@keyframes drift {
            from {
                transform: translate(0, 0) scale(1);
            }

            to {
                transform: translate(50px, -35px) scale(1.08);
            }
        }

        /* ── BRAND MARK ── */
        .brand-mark {
            position: fixed;
            top: 24px;
            left: 32px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 2;
        }

        .brand-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f97316, #fbbf24);
            box-shadow: 0 0 12px rgba(249,115,22,0.6);
        }

        .brand-name {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,0.28);
            letter-spacing: 0.5px;
        }

        /* ── CARD ── */
        .card {
            position: relative;
            z-index: 1;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 28px;
            padding: 52px 44px 44px;
            max-width: 460px;
            width: 92%;
            text-align: center;
            box-shadow: 0 32px 64px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── ICON RING ── */
        .icon-ring {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            position: relative;
            animation: popIn 0.5s 0.3s cubic-bezier(0.16,1,0.3,1) both;
        }

            .icon-ring::before {
                content: '';
                position: absolute;
                inset: -8px;
                border-radius: 50%;
            }

            .icon-ring i {
                font-size: 40px;
            }

        /* Success icon */
        .state-success .icon-ring {
            background: rgba(34,197,94,0.1);
            border: 1.5px solid rgba(34,197,94,0.25);
        }

            .state-success .icon-ring::before {
                border: 1px solid rgba(34,197,94,0.12);
            }

            .state-success .icon-ring i {
                color: #22c55e;
                filter: drop-shadow(0 0 14px rgba(34,197,94,0.45));
            }

        /* Error icon */
        .state-error .icon-ring {
            background: rgba(239,68,68,0.1);
            border: 1.5px solid rgba(239,68,68,0.25);
        }

            .state-error .icon-ring::before {
                border: 1px solid rgba(239,68,68,0.12);
            }

            .state-error .icon-ring i {
                color: #ef4444;
                filter: drop-shadow(0 0 14px rgba(239,68,68,0.45));
            }

        @@keyframes popIn {
            from {
                opacity: 0;
                transform: scale(0.7);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* ── BADGE ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

            .status-badge::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                animation: blink 2s infinite;
            }

        .state-success .status-badge {
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.22);
            color: #4ade80;
        }

            .state-success .status-badge::before {
                background: #22c55e;
            }

        .state-error .status-badge {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.22);
            color: #f87171;
        }

            .state-error .status-badge::before {
                background: #ef4444;
            }

        /* ── DIVIDER ── */
        .divider {
            width: 48px;
            height: 4px;
            border-radius: 10px;
            margin: 18px auto;
        }

        .state-success .divider {
            background: linear-gradient(90deg, #f97316, #fbbf24);
        }

        .state-error .divider {
            background: linear-gradient(90deg, #ef4444, #f97316);
        }

        /* ── TEXT ── */
        .card-title {
            font-size: 26px;
            font-weight: 800;
            color: #f1f5f9;
            letter-spacing: -0.4px;
            margin-bottom: 12px;
        }

        .card-msg {
            font-size: 14px;
            line-height: 1.75;
            color: #64748b;
            margin-bottom: 32px;
        }

        /* ── INSTRUCTION BOX ── */
        .instruction-box {
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            text-align: left;
            margin-bottom: 32px;
        }

        .state-success .instruction-box {
            background: rgba(249,115,22,0.07);
            border: 1px solid rgba(249,115,22,0.18);
        }

        .state-error .instruction-box {
            background: rgba(239,68,68,0.07);
            border: 1px solid rgba(239,68,68,0.18);
        }

        .instruction-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            flex-shrink: 0;
            font-size: 17px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .state-success .instruction-icon {
            background: rgba(249,115,22,0.12);
            border: 1px solid rgba(249,115,22,0.2);
            color: #f97316;
        }

        .state-error .instruction-icon {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.2);
            color: #ef4444;
        }

        .instruction-title {
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .state-success .instruction-title {
            color: #fb923c;
        }

        .state-error .instruction-title {
            color: #f87171;
        }

        .instruction-body {
            font-size: 12.5px;
            line-height: 1.6;
        }

        .state-success .instruction-body {
            color: #92400e;
        }

        .state-error .instruction-body {
            color: #991b1b;
        }

        /* ── RETRY BUTTON ── */
        .retry-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: transform 0.2s, box-shadow 0.2s;
            background: linear-gradient(135deg, #f97316, #fbbf24);
            color: white;
            box-shadow: 0 4px 15px rgba(249,115,22,0.3);
            margin-bottom: 12px;
        }

            .retry-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(249,115,22,0.4);
            }

        /* ── FOOTER ── */
        .card-footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.06);
            font-size: 12px;
            color: rgba(255,255,255,0.25);
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }
    </style>
</head>
<body class="@(success ? "state-success" : "state-error")">

    <!-- Background -->
    <div class="bg-layer">
        <div class="bg-grid"></div>
        <div class="bg-orb o1"></div>
        <div class="bg-orb o2"></div>
        <div class="bg-orb o3"></div>
    </div>

    <!-- Brand -->
    <div class="brand-mark">
        <div class="brand-dot"></div>
        <span class="brand-name">BelieveIn</span>
    </div>

    <!-- Card -->
    <div class="card">

        @if (success)
        {
            <!-- ✅ SUCCESS STATE -->
            <div class="icon-ring">
                <i class="mdi mdi-check-decagram"></i>
            </div>

            <div class="status-badge">Verified</div>

            <div class="card-title">@title</div>
            <div class="divider"></div>

            <p class="card-msg">@message</p>

            <div class="instruction-box">
                <div class="instruction-icon">
                    <i class="mdi mdi-cellphone-check"></i>
                </div>
                <div>
                    <div class="instruction-title">What's next?</div>
                    <div class="instruction-body">
                        You can safely close this window and open the BelieveIn app.
                        Sign in with your email and password to get started.
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- ❌ ERROR STATE -->
            <div class="icon-ring">
                <i class="mdi mdi-alert-circle-outline"></i>
            </div>

            <div class="status-badge">Failed</div>

            <div class="card-title">@title</div>
            <div class="divider"></div>

            <p class="card-msg">@message</p>

            <div class="instruction-box">
                <div class="instruction-icon">
                    <i class="mdi mdi-information-outline"></i>
                </div>
                <div>
                    <div class="instruction-title">What can you do?</div>
                    <div class="instruction-body">
                        Open the BelieveIn app and request a new confirmation email
                        from the sign-in screen. Confirmation links expire after some time
                        for security reasons.
                    </div>
                </div>
            </div>

            <a href="javascript:void(0)" class="retry-btn" onclick="openApp()">
                <i class="mdi mdi-cellphone-arrow-down"></i>
                Open BelieveIn App
            </a>
        }

        <div class="card-footer">
            &copy; @DateTime.Now.Year BelieveIn App. All rights reserved.
        </div>

    </div>

    <script>
        // Parallax orbs on mouse move
        document.addEventListener('mousemove', function (e) {
            var xPct = (e.clientX / window.innerWidth - 0.5) * 25;
            var yPct = (e.clientY / window.innerHeight - 0.5) * 18;
            document.querySelectorAll('.bg-orb').forEach(function (orb, i) {
                var f = (i + 1) * 0.5;
                orb.style.transform = 'translate(' + (xPct * f) + 'px, ' + (yPct * f) + 'px)';
            });
        });

        function openApp() {
            window.location.href = 'believein://home';
            setTimeout(function () {
                window.location.href = 'https://play.google.com/store/apps/details?id=com.believein.app';
            }, 2000);
        }
    </script>

</body>
</html>
