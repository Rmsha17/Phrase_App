@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BelieveIn | Email Confirmed</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@mdi/font@7.2.96/css/materialdesignicons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0f1623;
            overflow: hidden;
            position: relative;
        }

        /* ── BACKGROUND ── */
        .bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
        }

        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.5;
            animation: drift 20s ease-in-out infinite alternate;
        }

            .bg-orb.o1 {
                width: 480px;
                height: 480px;
                background: radial-gradient(circle, rgba(249,115,22,0.45), transparent 70%);
                top: -140px;
                left: -140px;
                animation-duration: 22s;
            }

            .bg-orb.o2 {
                width: 360px;
                height: 360px;
                background: radial-gradient(circle, rgba(34,197,94,0.2), transparent 70%);
                bottom: -80px;
                right: -80px;
                animation-duration: 28s;
                animation-direction: alternate-reverse;
            }

            .bg-orb.o3 {
                width: 260px;
                height: 260px;
                background: radial-gradient(circle, rgba(251,191,36,0.2), transparent 70%);
                top: 55%;
                left: 65%;
                animation-duration: 16s;
            }

        @@keyframes drift {
            from {
                transform: translate(0, 0) scale(1);
            }

            to {
                transform: translate(50px, -35px) scale(1.08);
            }
        }

        /* ── BRAND MARK ── */
        .brand-mark {
            position: fixed;
            top: 24px;
            left: 32px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 2;
        }

        .brand-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f97316, #fbbf24);
            box-shadow: 0 0 12px rgba(249,115,22,0.6);
        }

        .brand-name {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,0.28);
            letter-spacing: 0.5px;
        }

        /* ── CARD ── */
        .card {
            position: relative;
            z-index: 1;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 28px;
            padding: 52px 44px 44px;
            max-width: 460px;
            width: 92%;
            text-align: center;
            box-shadow: 0 32px 64px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── SUCCESS ICON ── */
        .icon-ring {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: rgba(34,197,94,0.1);
            border: 1.5px solid rgba(34,197,94,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            position: relative;
            animation: popIn 0.5s 0.3s cubic-bezier(0.16,1,0.3,1) both;
        }

            .icon-ring::before {
                content: '';
                position: absolute;
                inset: -8px;
                border-radius: 50%;
                border: 1px solid rgba(34,197,94,0.12);
            }

            .icon-ring i {
                font-size: 40px;
                color: #22c55e;
                filter: drop-shadow(0 0 14px rgba(34,197,94,0.45));
            }

        @@keyframes popIn {
            from {
                opacity: 0;
                transform: scale(0.7);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* ── BADGE ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(34,197,94,0.1);
            border: 1px solid rgba(34,197,94,0.22);
            color: #4ade80;
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

            .status-badge::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #22c55e;
                animation: blink 2s infinite;
            }

        /* ── DIVIDER ── */
        .divider {
            width: 48px;
            height: 4px;
            background: linear-gradient(90deg, #f97316, #fbbf24);
            border-radius: 10px;
            margin: 18px auto;
        }

        /* ── TEXT ── */
        .card-title {
            font-size: 26px;
            font-weight: 800;
            color: #f1f5f9;
            letter-spacing: -0.4px;
            margin-bottom: 12px;
        }

        .card-msg {
            font-size: 14px;
            line-height: 1.75;
            color: #64748b;
            margin-bottom: 32px;
        }

        /* ── INSTRUCTION BOX ── */
        .instruction-box {
            background: rgba(249,115,22,0.07);
            border: 1px solid rgba(249,115,22,0.18);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            text-align: left;
            margin-bottom: 32px;
        }

        .instruction-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            flex-shrink: 0;
            background: rgba(249,115,22,0.12);
            border: 1px solid rgba(249,115,22,0.2);
            color: #f97316;
            font-size: 17px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .instruction-title {
            font-size: 12px;
            font-weight: 700;
            color: #fb923c;
            margin-bottom: 4px;
        }

        .instruction-body {
            font-size: 12.5px;
            color: #92400e;
            line-height: 1.6;
        }

        /* ── FOOTER ── */
        .card-footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.06);
            font-size: 12px;
            color: #ffffff;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }
    </style>
</head>
<body>

    <!-- Background -->
    <div class="bg-layer">
        <div class="bg-grid"></div>
        <div class="bg-orb o1"></div>
        <div class="bg-orb o2"></div>
        <div class="bg-orb o3"></div>
    </div>

    <!-- Brand -->
    <div class="brand-mark">
        <div class="brand-dot"></div>
        <span class="brand-name">BelieveIn</span>
    </div>

    <!-- Card -->
    <div class="card">

        <!-- Icon -->
        <div class="icon-ring">
            <i class="mdi mdi-check-decagram"></i>
        </div>

        <!-- Badge -->
        <div class="status-badge">Verified</div>

        <!-- Title -->
        <div class="card-title">Email Confirmed!</div>

        <div class="divider"></div>

        <!-- Message -->
        <p class="card-msg">
            Your account is now active and ready to go.
            Return to the BelieveIn app to start your journey.
        </p>

        <!-- Instruction box -->
        <div class="instruction-box">
            <div class="instruction-icon">
                <i class="mdi mdi-cellphone-check"></i>
            </div>
            <div>
                <div class="instruction-title">What's next?</div>
                <div class="instruction-body">
                    You can safely close this window and open the BelieveIn app.
                    Your account will be logged in automatically.
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="card-footer">
            &copy; @DateTime.Now.Year BelieveIn App. All rights reserved.
        </div>

    </div>

    <script>
        // Parallax orbs on mouse move
        document.addEventListener('mousemove', function (e) {
            var xPct = (e.clientX / window.innerWidth  - 0.5) * 25;
            var yPct = (e.clientY / window.innerHeight - 0.5) * 18;
            document.querySelectorAll('.bg-orb').forEach(function (orb, i) {
                var f = (i + 1) * 0.5;
                orb.style.transform = 'translate(' + (xPct * f) + 'px, ' + (yPct * f) + 'px)';
            });
        });
    </script>

</body>
</html>