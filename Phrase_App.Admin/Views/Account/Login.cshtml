@model Phrase_App.Core.DTOs.Auth.LoginDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BelieveIn Admin | Sign In</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@mdi/font@7.2.96/css/materialdesignicons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0b1120;
            overflow: hidden;
        }

        /* ── LEFT PANEL ── */
        .left-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background: linear-gradient(145deg, #0f1a2e 0%, #0b1120 100%);
        }

        /* Animated orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.6;
            animation: driftOrb 20s ease-in-out infinite alternate;
        }

        .orb-1 {
            width: 480px;
            height: 480px;
            background: radial-gradient(circle, rgba(249,115,22,0.45), transparent 70%);
            top: -120px;
            left: -100px;
            animation-duration: 22s;
        }

        .orb-2 {
            width: 360px;
            height: 360px;
            background: radial-gradient(circle, rgba(251,191,36,0.3), transparent 70%);
            bottom: -80px;
            right: -60px;
            animation-duration: 18s;
            animation-direction: alternate-reverse;
        }

        .orb-3 {
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(249,115,22,0.2), transparent 70%);
            top: 55%;
            left: 55%;
            animation-duration: 14s;
        }

        /* Grid */
        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(249,115,22,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.05) 1px, transparent 1px);
            background-size: 52px 52px;
        }

        @@keyframes driftOrb {
            from {
                transform: translate(0, 0) scale(1);
            }

            to {
                transform: translate(50px, -40px) scale(1.12);
            }
        }

        /* Left panel content */
        .left-content {
            position: relative;
            z-index: 1;
            padding: 48px;
            max-width: 480px;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 60px;
        }

            .brand-logo img {
                width: 48px;
                height: 48px;
                border-radius: 14px;
                box-shadow: 0 0 28px rgba(249,115,22,0.4);
            }

        .brand-logo-text {
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.3px;
        }

            .brand-logo-text span {
                color: #f97316;
            }

        .left-headline {
            font-size: clamp(28px, 3.5vw, 42px);
            font-weight: 900;
            color: #fff;
            line-height: 1.15;
            letter-spacing: -1px;
            margin-bottom: 18px;
        }

            .left-headline em {
                font-style: normal;
                background: linear-gradient(135deg, #f97316, #fbbf24);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .left-desc {
            font-size: 15px;
            color: #64748b;
            line-height: 1.75;
            margin-bottom: 44px;
        }

        /* Feature pills */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .feature-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            flex-shrink: 0;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.2);
            color: #f97316;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .feature-text-title {
            font-size: 13px;
            font-weight: 700;
            color: #e2e8f0;
        }

        .feature-text-sub {
            font-size: 12px;
            color: #475569;
            margin-top: 1px;
        }

        /* ── RIGHT PANEL (Login Form) ── */
        .right-panel {
            width: 480px;
            min-width: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0d1526;
            border-left: 1px solid rgba(255,255,255,0.06);
            padding: 40px 48px;
            position: relative;
            z-index: 1;
        }

        .login-box {
            width: 100%;
            animation: slideUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Form header */
        .form-header {
            margin-bottom: 36px;
        }

        .form-header-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.2);
            color: #fb923c;
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

            .form-header-badge::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #f97316;
                animation: blink 2s infinite;
            }

        .form-title {
            font-size: 26px;
            font-weight: 800;
            color: #f1f5f9;
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .form-subtitle {
            font-size: 13px;
            color: #475569;
        }

        /* ── INPUT FIELDS ── */
        .field-group {
            margin-bottom: 20px;
        }

        .field-label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            letter-spacing: 0.6px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .field-wrap {
            position: relative;
            display: flex;
            align-items: center;
            background: rgba(255,255,255,0.03);
            border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            overflow: hidden;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }

            .field-wrap:focus-within {
                border-color: rgba(249,115,22,0.5);
                box-shadow: 0 0 0 4px rgba(249,115,22,0.1);
                background: rgba(249,115,22,0.03);
            }

        .field-icon {
            padding: 0 14px 0 16px;
            color: #334155;
            font-size: 18px;
            display: flex;
            align-items: center;
            transition: color 0.2s;
        }

        .field-wrap:focus-within .field-icon {
            color: #f97316;
        }

        .field-input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: #f1f5f9;
            font-size: 14px;
            font-weight: 500;
            padding: 14px 16px 14px 0;
        }

            .field-input::placeholder {
                color: #2d3f55;
            }

        .field-toggle {
            padding: 0 14px;
            cursor: pointer;
            color: #334155;
            font-size: 18px;
            background: none;
            border: none;
            outline: none;
            display: flex;
            align-items: center;
            transition: color 0.2s;
        }

            .field-toggle:hover {
                color: #f97316;
            }

        /* ── ERROR ALERT ── */
        .error-alert {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 12px;
            padding: 13px 15px;
            margin-bottom: 22px;
        }

            .error-alert i {
                color: #f87171;
                font-size: 16px;
                margin-top: 1px;
                flex-shrink: 0;
            }

        .error-alert-body {
            font-size: 13px;
            color: #fca5a5;
            line-height: 1.5;
        }

            .error-alert-body ul {
                list-style: none;
            }

        /* ── SUBMIT BUTTON ── */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.3px;
            box-shadow: 0 8px 24px rgba(249,115,22,0.35);
            transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 8px;
        }

            .btn-submit:hover {
                opacity: 0.9;
                transform: translateY(-2px);
                box-shadow: 0 16px 32px rgba(249,115,22,0.45);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

            .btn-submit:disabled {
                opacity: 0.65;
                cursor: not-allowed;
                transform: none;
            }

        /* Spinner */
        .spinner {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            animation: spin 0.7s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── FOOTER ── */
        .form-footer {
            text-align: center;
            margin-top: 28px;
            font-size: 11px;
            color: #ffffff;
            border-top: 1px solid rgba(255,255,255,0.04);
            padding-top: 20px;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 820px) {
            .left-panel {
                display: none;
            }

            .right-panel {
                width: 100%;
                min-width: unset;
                border: none;
            }
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }
    </style>
</head>

<body>

    <!-- ── LEFT DECORATIVE PANEL ── -->
    <div class="left-panel">
        <div class="bg-grid"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="left-content">
            <div class="brand-logo">
                <img src="~/admin/assets/images/1400.png" alt="BelieveIn Logo" />
                <span class="brand-logo-text">Believe<span>In</span> Admin</span>
            </div>

            <h1 class="left-headline">
                Manage your<br />
                <em>affirmation platform</em><br />
                with confidence.
            </h1>

            <p class="left-desc">
                Full control over users, content, subscriptions and
                real-time analytics — all from one secure dashboard.
            </p>

            <div class="feature-list">
                <div class="feature-item">
                    <div class="feature-icon"><i class="mdi mdi-account-group-outline"></i></div>
                    <div>
                        <div class="feature-text-title">User Management</div>
                        <div class="feature-text-sub">Manage accounts, roles and subscription status</div>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon"><i class="mdi mdi-format-quote-open"></i></div>
                    <div>
                        <div class="feature-text-title">Content Library</div>
                        <div class="feature-text-sub">Create and organize affirmations by category</div>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon"><i class="mdi mdi-chart-areaspline"></i></div>
                    <div>
                        <div class="feature-text-title">Live Analytics</div>
                        <div class="feature-text-sub">Engagement, subscriptions and error reporting</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RIGHT LOGIN PANEL ── -->
    <div class="right-panel">
        <div class="login-box">

            <div class="form-header">
                <div class="form-header-badge">Secure Access</div>
                <div class="form-title">Welcome back</div>
                <div class="form-subtitle">Sign in with your administrator credentials</div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-alert">
                    <i class="mdi mdi-alert-circle-outline"></i>
                    <div class="error-alert-body">
                        <div asp-validation-summary="All"></div>
                    </div>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" id="loginForm">
                @Html.AntiForgeryToken()

                <!-- Email -->
                <div class="field-group">
                    <label class="field-label">Email Address</label>
                    <div class="field-wrap">
                        <div class="field-icon"><i class="mdi mdi-email-outline"></i></div>
                        <input asp-for="Email" type="email" class="field-input"
                               placeholder="admin@believein.app" required autocomplete="email" />
                    </div>
                </div>

                <!-- Password -->
                <div class="field-group">
                    <label class="field-label">Password</label>
                    <div class="field-wrap">
                        <div class="field-icon"><i class="mdi mdi-lock-outline"></i></div>
                        <input asp-for="Password" type="password" class="field-input"
                               placeholder="••••••••" required id="passwordInput" autocomplete="current-password" />
                        <button type="button" class="field-toggle" id="togglePassword" tabindex="-1" title="Toggle visibility">
                            <i class="mdi mdi-eye-outline" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="submitBtn">
                    <span class="spinner" id="spinner"></span>
                    <span id="btnText">Sign In to Dashboard</span>
                    <i class="mdi mdi-arrow-right" id="btnArrow"></i>
                </button>

            </form>

            <div class="form-footer">
                &copy; @DateTime.Now.Year BelieveIn App &mdash; All rights reserved.
            </div>

        </div>
    </div>

    <script>
        // ── Password toggle ──
        document.getElementById('togglePassword').addEventListener('click', function () {
            var input = document.getElementById('passwordInput');
            var icon  = document.getElementById('eyeIcon');
            var isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            icon.className = isHidden ? 'mdi mdi-eye-off-outline' : 'mdi mdi-eye-outline';
        });

        // ── Loading state on submit ──
        document.getElementById('loginForm').addEventListener('submit', function () {
            if (this.checkValidity()) {
                var btn     = document.getElementById('submitBtn');
                var spinner = document.getElementById('spinner');
                var text    = document.getElementById('btnText');
                var arrow   = document.getElementById('btnArrow');

                spinner.style.display = 'block';
                text.textContent      = 'Signing In…';
                arrow.style.display   = 'none';
                btn.disabled          = true;
            }
        });

        // ── Subtle parallax on orbs ──
        document.addEventListener('mousemove', function (e) {
            var xPct = (e.clientX / window.innerWidth  - 0.5) * 24;
            var yPct = (e.clientY / window.innerHeight - 0.5) * 18;
            document.querySelectorAll('.orb').forEach(function (orb, i) {
                var f = (i + 1) * 0.5;
                orb.style.transform = 'translate(' + (xPct * f) + 'px, ' + (yPct * f) + 'px)';
            });
        });
    </script>

</body>
</html>