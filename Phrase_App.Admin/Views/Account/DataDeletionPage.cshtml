@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BelieveIn | Data Deletion</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@mdi/font@7.2.96/css/materialdesignicons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0f1623;
            overflow-x: hidden;
            position: relative;
            padding: 48px 20px;
        }

        /* ── BACKGROUND ── */
        .bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .bg-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(249,115,22,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
        }

        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.5;
            animation: drift 20s ease-in-out infinite alternate;
        }

            .bg-orb.o1 {
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(249,115,22,0.45), transparent 70%);
                top: -140px;
                left: -140px;
                animation-duration: 22s;
            }

            .bg-orb.o2 {
                width: 380px;
                height: 380px;
                background: radial-gradient(circle, rgba(251,191,36,0.25), transparent 70%);
                bottom: 10%;
                right: -100px;
                animation-duration: 28s;
                animation-direction: alternate-reverse;
            }

            .bg-orb.o3 {
                width: 260px;
                height: 260px;
                background: radial-gradient(circle, rgba(249,115,22,0.2), transparent 70%);
                top: 40%;
                left: 60%;
                animation-duration: 16s;
            }

        @@keyframes drift {
            from {
                transform: translate(0, 0) scale(1);
            }

            to {
                transform: translate(50px, -35px) scale(1.08);
            }
        }

        /* ── BRAND ── */
        .brand-mark {
            position: fixed;
            top: 24px;
            left: 32px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 10;
        }

        .brand-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f97316, #fbbf24);
            box-shadow: 0 0 12px rgba(249,115,22,0.6);
        }

        .brand-name {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,0.28);
            letter-spacing: 0.5px;
        }

        /* ── CARD ── */
        .card {
            position: relative;
            z-index: 1;
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 28px;
            padding: 48px 44px;
            max-width: 720px;
            width: 100%;
            box-shadow: 0 32px 64px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.08);
            animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── PAGE HEADER ── */
        .page-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.22);
            color: #fb923c;
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

            .page-badge i {
                font-size: 13px;
            }

        .page-title {
            font-size: 32px;
            font-weight: 900;
            color: #f1f5f9;
            letter-spacing: -0.8px;
            line-height: 1.1;
            margin-bottom: 12px;
        }

            .page-title span {
                background: linear-gradient(135deg, #f97316, #fbbf24);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .page-intro {
            font-size: 14px;
            color: #64748b;
            line-height: 1.75;
            margin-bottom: 36px;
        }

        /* ── DIVIDER ── */
        .section-divider {
            width: 48px;
            height: 4px;
            background: linear-gradient(90deg, #f97316, #fbbf24);
            border-radius: 10px;
            margin-bottom: 32px;
        }

        /* ── SECTION BLOCK ── */
        .section-block {
            margin-bottom: 28px;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .section-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            flex-shrink: 0;
            background: rgba(249,115,22,0.1);
            border: 1px solid rgba(249,115,22,0.2);
            color: #f97316;
            font-size: 19px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #f1f5f9;
        }

        .section-body {
            font-size: 13.5px;
            color: #64748b;
            line-height: 1.75;
            margin-bottom: 16px;
        }

        /* ── STEPS LIST ── */
        .steps-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .steps-list li {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.06);
                border-radius: 14px;
                padding: 14px 16px;
                font-size: 13.5px;
                color: #94a3b8;
                line-height: 1.6;
                transition: background 0.2s, border-color 0.2s;
            }

                .steps-list li:hover {
                    background: rgba(249,115,22,0.05);
                    border-color: rgba(249,115,22,0.15);
                }

        .step-num {
            width: 24px;
            height: 24px;
            border-radius: 8px;
            flex-shrink: 0;
            background: linear-gradient(135deg, #f97316, #fbbf24);
            color: #fff;
            font-size: 11px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 1px;
            box-shadow: 0 3px 10px rgba(249,115,22,0.3);
        }

        .steps-list li strong {
            color: #f1f5f9;
            font-weight: 700;
        }

        /* ── HIGHLIGHT / EMAIL BOX ── */
        .email-box {
            background: rgba(249,115,22,0.07);
            border: 1.5px solid rgba(249,115,22,0.2);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 16px 0;
        }

        .email-icon {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            flex-shrink: 0;
            background: rgba(249,115,22,0.12);
            border: 1px solid rgba(249,115,22,0.2);
            color: #f97316;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .email-label {
            font-size: 11px;
            font-weight: 700;
            color: #f97316;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .email-addr {
            font-size: 14px;
            font-weight: 700;
            color: #f1f5f9;
        }

        /* ── INFO BOX ── */
        .info-box {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 14px;
            padding: 16px 18px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-top: 12px;
            font-size: 13px;
            color: #475569;
            line-height: 1.65;
        }

            .info-box i {
                color: #64748b;
                font-size: 16px;
                flex-shrink: 0;
                margin-top: 1px;
            }

        /* ── SEPARATOR ── */
        .separator {
            height: 1px;
            background: rgba(255,255,255,0.06);
            margin: 28px 0;
        }

        /* ── FOOTER ── */
        .card-footer {
            text-align: center;
            font-size: 12px;
            color: #ffffff;
            padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }
        }
    </style>
</head>
<body>

    <!-- Background -->
    <div class="bg-layer">
        <div class="bg-grid"></div>
        <div class="bg-orb o1"></div>
        <div class="bg-orb o2"></div>
        <div class="bg-orb o3"></div>
    </div>

    <!-- Brand -->
    <div class="brand-mark">
        <div class="brand-dot"></div>
        <span class="brand-name">BelieveIn</span>
    </div>

    <!-- Card -->
    <div class="card">

        <!-- Header -->
        <div class="page-badge">
            <i class="mdi mdi-shield-account-outline"></i>
            Data & Privacy
        </div>

        <div class="page-title">Data <span>Deletion</span> Request</div>

        <div class="section-divider"></div>

        <p class="page-intro">
            At <strong style="color:#f1f5f9;">BelieveIn</strong>, we respect your right to manage and remove your personal data.
            Follow the steps below to revoke app access or permanently delete your account information from our systems.
        </p>

        <!-- Section 1: Facebook -->
        <div class="section-block">
            <div class="section-header">
                <div class="section-icon">
                    <i class="mdi mdi-facebook"></i>
                </div>
                <div class="section-title">Deletion via Facebook</div>
            </div>

            <p class="section-body">
                If you signed in using Facebook, you can remove BelieveIn's access to your data directly through your Facebook account settings.
            </p>

            <ol class="steps-list">
                <li>
                    <span class="step-num">1</span>
                    <span>Go to your Facebook Account's <strong>Settings & Privacy</strong>.</span>
                </li>
                <li>
                    <span class="step-num">2</span>
                    <span>Click on <strong>Settings</strong>.</span>
                </li>
                <li>
                    <span class="step-num">3</span>
                    <span>Look for <strong>Apps and Websites</strong> to see all apps linked to your Facebook account.</span>
                </li>
                <li>
                    <span class="step-num">4</span>
                    <span>Search for <strong>BelieveIn</strong> and click the <strong>Remove</strong> button.</span>
                </li>
                <li>
                    <span class="step-num">5</span>
                    <span>Confirm the removal. BelieveIn will no longer have access to your Facebook data.</span>
                </li>
            </ol>
        </div>

        <div class="separator"></div>

        <!-- Section 2: Server deletion -->
        <div class="section-block">
            <div class="section-header">
                <div class="section-icon">
                    <i class="mdi mdi-database-remove-outline"></i>
                </div>
                <div class="section-title">Delete Data from Our Servers</div>
            </div>

            <p class="section-body">
                To permanently delete your account and all associated data from our internal systems, contact us directly using the email address below.
            </p>

            <div class="email-box">
                <div class="email-icon">
                    <i class="mdi mdi-email-outline"></i>
                </div>
                <div>
                    <div class="email-label">Contact us at</div>
                    <div class="email-addr">getbelievein@gmail.com</div>
                </div>
            </div>

            <div class="info-box">
                <i class="mdi mdi-information-outline"></i>
                <span>
                    Please include the email address used during sign-up in your message.
                    We will process your request and permanently remove your data within
                    <strong style="color:#94a3b8;">7 business days</strong>.
                </span>
            </div>
        </div>

        <!-- Footer -->
        <div class="card-footer">
            &copy; @DateTime.UtcNow.Year BelieveIn App. All rights reserved.
        </div>

    </div>

    <script>
        document.addEventListener('mousemove', function (e) {
            var xPct = (e.clientX / window.innerWidth  - 0.5) * 25;
            var yPct = (e.clientY / window.innerHeight - 0.5) * 18;
            document.querySelectorAll('.bg-orb').forEach(function (orb, i) {
                var f = (i + 1) * 0.5;
                orb.style.transform = 'translate(' + (xPct * f) + 'px, ' + (yPct * f) + 'px)';
            });
        });
    </script>

</body>
</html>