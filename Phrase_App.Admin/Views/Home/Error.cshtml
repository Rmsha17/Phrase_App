@{
    // Dynamic values provided by ErrorHandlingMiddleware
    var errorCode = ViewData["ErrorCode"]?.ToString() ?? (Context.Response?.StatusCode.ToString() ?? "Error");
    var errorMessage = ViewData["ErrorMessage"]?.ToString() ?? "PAGE NOT FOUND !";
    var requestId = ViewData["RequestId"]?.ToString();
    var showRequestId = (ViewData["ShowRequestId"] as bool?) ?? false;
}
<!DOCTYPE html>
<html dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <!-- Tell the browser to be responsive to screen width -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="keywords"
          content="wrappixel, admin dashboard, html css dashboard, web dashboard, bootstrap 5 admin, bootstrap 5, css3 dashboard, bootstrap 5 dashboard, Matrix lite admin bootstrap 5 dashboard, frontend, responsive bootstrap 5 admin template, Matrix admin lite design, Matrix admin lite dashboard bootstrap 5 dashboard template" />
    <meta name="description"
          content="BelieveIn Admin Lite Free Version is powerful and clean admin dashboard" />
    <meta name="robots" content="noindex,nofollow" />
    <title>BelieveIn - Error @errorCode</title>
    <!-- Favicon icon -->
    <link rel="icon"
          type="image/png"
          sizes="16x16"
          href="~/Admin/assets/images/favicon.png" />
    <!-- Custom CSS -->
    <link href="~/Admin/dist/css/style.min.css" rel="stylesheet" />
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js"></script>
      <script src="https://oss.maxcdn.com/libs/respond.js/1.4.2/respond.min.js"></script>
    <![endif]-->
</head>

<body>
    <div class="main-wrapper">
        <!-- ============================================================== -->
        <!-- Preloader - style you can find in spinners.css -->
        <!-- ============================================================== -->
        <div class="preloader">
            <div class="lds-ripple">
                <div class="lds-pos"></div>
                <div class="lds-pos"></div>
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- Preloader - style you can find in spinners.css -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Login box.scss -->
        <!-- ============================================================== -->
        <div class="error-box">
            <div class="error-body text-center">
                <h1 class="error-title text-danger">@errorCode</h1>
                <h3 class="text-uppercase error-subtitle">@Html.Raw(System.Net.WebUtility.HtmlEncode(errorMessage))</h3>
                <p class="text-muted mt-4 mb-4">
                    You seem to be trying to find your way home.
                </p>

                <div class="mb-3">
                    <a href="~/" class="btn btn-danger btn-rounded waves-effect waves-light mb-2 text-white">Back to
                       home</a>
                    <a href="javascript:history.back()"
                       class="btn btn-secondary btn-rounded waves-effect waves-light mb-2 ms-2">Go Back</a>
                </div>

                @if (showRequestId || !string.IsNullOrEmpty(requestId) || !string.IsNullOrEmpty(errorMessage))
                {
                    <div class="card mt-3 mx-auto" style="max-width:760px;">
                        <div class="card-body text-start">
                            <h6 class="card-title">Error details</h6>
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Code</dt>
                                <dd class="col-sm-9">@errorCode</dd>

                                <dt class="col-sm-3">Message</dt>
                                <dd class="col-sm-9"
                                    title="@errorMessage">@Html.Raw(System.Net.WebUtility.HtmlEncode(errorMessage).Length > 200 ? System.Net.WebUtility.HtmlEncode(errorMessage).Substring(0, 200) + "…" : System.Net.WebUtility.HtmlEncode(errorMessage))</dd>

                                @if (showRequestId && !string.IsNullOrEmpty(requestId))
                                {
                                    <dt class="col-sm-3">Request Id</dt>
                                    <dd class="col-sm-9">@requestId</dd>
                                }
                            </dl>
                        </div>
                    </div>
                }
            </div>
        </div>
        <!-- ============================================================== -->
        <!-- Login box.scss -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Page wrapper scss in scafholding.scss -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Page wrapper scss in scafholding.scss -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Right Sidebar -->
        <!-- ============================================================== -->
        <!-- ============================================================== -->
        <!-- Right Sidebar -->
        <!-- ============================================================== -->
    </div>
    <!-- ============================================================== -->
    <!-- All Required js -->
    <!-- ============================================================== -->
    <script src="~/Admin/assets/libs/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap tether Core JavaScript -->
    <script src="~/Admin/assets/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- ============================================================== -->
    <!-- This page plugin js -->
    <!-- ============================================================== -->
    <script>
        $(".preloader").fadeOut();
    </script>
</body>
</html>
