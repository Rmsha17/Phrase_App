@{
    ViewData["Title"] = "Bulk Upload Quotes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = (IEnumerable<Phrase_App.Core.Models.Category>)ViewBag.Categories ?? new List<Phrase_App.Core.Models.Category>();
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .breadcrumb-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

        .breadcrumb-link:hover {
            color: var(--orange);
        }

    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 32px;
        box-shadow: var(--card-shadow);
    }

    .form-section {
        margin-bottom: 28px;
    }

    .form-section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-section-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .form-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    .form-label {
        font-size: 13px !important;
        font-weight: 600 !important;
        color: var(--text) !important;
        margin-bottom: 7px !important;
    }

    .form-hint {
        font-size: 12px;
        color: var(--muted-light);
        margin-top: 6px;
    }

    .form-control,
    .form-select {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 12px !important;
        font-size: 14px !important;
        color: var(--text) !important;
        transition: border-color 0.2s, box-shadow 0.2s !important;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.12) !important;
            background: #fff !important;
            outline: none !important;
        }

    /* ── FORMAT INFO BANNER ── */
    .format-banner {
        background: #eff6ff;
        border: 1.5px solid #bfdbfe;
        border-radius: 16px;
        padding: 18px 20px;
        margin-bottom: 28px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
    }

    .format-banner-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: #dbeafe;
        color: #2563eb;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .format-banner-title {
        font-size: 13px;
        font-weight: 700;
        color: #1e40af;
        margin-bottom: 6px;
    }

    .format-banner-body {
        font-size: 13px;
        color: #1d4ed8;
        line-height: 1.7;
    }

        .format-banner-body code {
            background: #dbeafe;
            color: #1e40af;
            border-radius: 5px;
            padding: 1px 7px;
            font-size: 12px;
            font-weight: 600;
            font-family: 'Courier New', monospace;
        }

    /* ── FILE DROP ZONE ── */
    .file-dropzone {
        border: 2px dashed var(--input-border);
        border-radius: 16px;
        padding: 40px 24px;
        text-align: center;
        background: var(--input-bg);
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }

        .file-dropzone:hover,
        .file-dropzone.dragover {
            border-color: var(--orange);
            background: var(--orange-light);
        }

        .file-dropzone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .dropzone-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        color: var(--orange);
        font-size: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 14px;
        transition: transform 0.2s;
    }

    .file-dropzone:hover .dropzone-icon {
        transform: scale(1.08);
    }

    .dropzone-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 5px;
    }

    .dropzone-sub {
        font-size: 12px;
        color: var(--muted);
    }

    .file-selected-info {
        display: none;
        align-items: center;
        gap: 12px;
        margin-top: 14px;
        padding: 12px 16px;
        background: #f0fdf4;
        border: 1.5px solid #bbf7d0;
        border-radius: 12px;
    }

        .file-selected-info.visible {
            display: flex;
        }

        .file-selected-info i {
            color: #16a34a;
            font-size: 20px;
            flex-shrink: 0;
        }

    .file-name {
        font-size: 13px;
        font-weight: 600;
        color: #15803d;
    }

    .file-size {
        font-size: 12px;
        color: #86efac;
        margin-left: auto;
    }

    /* ── CATEGORY PILL ── */
    .category-option-preview {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: var(--input-bg);
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        margin-top: 10px;
    }

    .category-option-dot {
        width: 12px;
        height: 12px;
        border-radius: 4px;
        flex-shrink: 0;
        transition: background 0.3s;
    }

    .category-option-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
    }

    /* ── BUTTONS ── */
    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--gradient);
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(249,115,22,0.35);
        transition: opacity 0.2s, transform 0.2s;
        text-decoration: none !important;
    }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f1f5f9;
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }

    /* ── SAMPLE FORMAT PANEL ── */
    .sample-panel {
        background: #1a2235;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 0;
    }

    .sample-panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #475569;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .sample-panel-title i {
            color: var(--orange);
        }

    .code-line {
        font-family: 'Courier New', monospace;
        font-size: 12.5px;
        line-height: 2;
        padding: 2px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .code-line.comment {
            color: #475569;
        }

        .code-line.quote-line {
            color: #cbd5e1;
        }

        .code-line .pipe {
            color: var(--orange);
            font-weight: 700;
        }

    /* ── STEPS BOX ── */
    .steps-box {
        margin-top: 0;
    }

    .step-row {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .step-row:last-child {
            border-bottom: none;
        }

    .step-num {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        color: var(--orange);
        font-size: 12px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .step-text {
        font-size: 13px;
        color: var(--text);
        line-height: 1.5;
        padding-top: 4px;
    }

        .step-text strong {
            color: var(--text);
            font-weight: 700;
        }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>Bulk Upload</h2>
        <p>Import multiple affirmations at once from a file</p>
    </div>
    <a class="breadcrumb-link" asp-area="Admin" asp-controller="Quotes" asp-action="Index">
        <i class="mdi mdi-arrow-left"></i> Back to Affirmations
    </a>
</div>

<div class="row g-4">

    <!-- Form Column -->
    <div class="col-lg-8">
        <div class="panel">

            <!-- Format Banner -->
            <div class="format-banner">
                <div class="format-banner-icon">
                    <i class="mdi mdi-information-outline"></i>
                </div>
                <div>
                    <div class="format-banner-title">File Format Guide</div>
                    <div class="format-banner-body">
                        Use a <code>.csv</code> or <code>.txt</code> file with <strong>one quote per line</strong>.<br />
                        Format: <code>QuoteText|Author</code> &nbsp;·&nbsp; Example: <code>Success is not final|Winston Churchill</code><br />
                        Lines starting with <code>#</code> are treated as comments and ignored.
                    </div>
                </div>
            </div>

            <form asp-area="Admin" asp-controller="Quotes" asp-action="BulkUpload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Category -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="mdi mdi-tag-multiple-outline"></i>
                        Target Category
                    </div>

                    <label class="form-label">Select Category</label>
                    <select name="categoryId" id="categorySelect" class="form-select" required>
                        <option value="">— Select a category —</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id"
                                    data-color="@cat.ColorHex"
                                    data-name="@cat.Name">
                                @cat.Name
                            </option>
                        }
                    </select>
                    <p class="form-hint">All quotes in the uploaded file will be assigned to this category.</p>

                    <div class="category-option-preview" id="catPreviewRow" style="display:none;">
                        <div class="category-option-dot" id="catPreviewDot"></div>
                        <span class="category-option-name" id="catPreviewName"></span>
                    </div>
                </div>

                <!-- File Upload -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="mdi mdi-upload-outline"></i>
                        Upload File
                    </div>

                    <div class="file-dropzone" id="dropzone">
                        <input type="file" name="file" id="fileInput" accept=".csv,.txt" required />
                        <div class="dropzone-icon">
                            <i class="mdi mdi-cloud-upload-outline"></i>
                        </div>
                        <div class="dropzone-title">Drop your file here or click to browse</div>
                        <div class="dropzone-sub">Accepts .csv and .txt files · Max 10 MB</div>
                    </div>

                    <div class="file-selected-info" id="fileInfo">
                        <i class="mdi mdi-file-check-outline"></i>
                        <span class="file-name" id="fileName">file.csv</span>
                        <span class="file-size" id="fileSize"></span>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 pt-2">
                    <button type="submit" class="btn-submit">
                        <i class="mdi mdi-upload"></i> Start Upload
                    </button>
                    <a asp-area="Admin" asp-controller="Quotes" asp-action="Index" class="btn-cancel">
                        <i class="mdi mdi-close"></i> Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- Right Column: Steps + Sample -->
    <div class="col-lg-4">
        <div style="position: sticky; top: 90px;">

            <!-- How it works -->
            <div class="panel" style="margin-bottom: 20px;">
                <div style="font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:#64748b; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i class="mdi mdi-numeric" style="color:#f97316; font-size:16px;"></i>
                    How it works
                </div>
                <div class="steps-box">
                    <div class="step-row">
                        <div class="step-num">1</div>
                        <div class="step-text"><strong>Choose a category</strong> — all imported quotes will be assigned to it</div>
                    </div>
                    <div class="step-row">
                        <div class="step-num">2</div>
                        <div class="step-text"><strong>Prepare your file</strong> — one quote per line using the pipe format</div>
                    </div>
                    <div class="step-row">
                        <div class="step-num">3</div>
                        <div class="step-text"><strong>Upload</strong> — duplicates are skipped automatically</div>
                    </div>
                    <div class="step-row">
                        <div class="step-num">4</div>
                        <div class="step-text"><strong>Review</strong> — a summary report shows successes and any skipped lines</div>
                    </div>
                </div>
            </div>

            <!-- Sample file -->
            <div class="panel">
                <div style="font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:#64748b; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i class="mdi mdi-file-code-outline" style="color:#f97316; font-size:16px;"></i>
                    Sample File
                </div>
                <div class="sample-panel">
                    <div class="sample-panel-title">
                        <i class="mdi mdi-code-tags"></i> quotes.csv
                    </div>
                    <div class="code-line comment">
                        <span># This is a comment — ignored</span>
                    </div>
                    <div class="code-line quote-line">
                        <span>Success is not final<span class="pipe">|</span>Winston Churchill</span>
                    </div>
                    <div class="code-line quote-line">
                        <span>Do great work<span class="pipe">|</span>Steve Jobs</span>
                    </div>
                    <div class="code-line quote-line">
                        <span>Be the change<span class="pipe">|</span>Gandhi</span>
                    </div>
                    <div class="code-line comment">
                        <span># Author is optional</span>
                    </div>
                    <div class="code-line quote-line">
                        <span>Every day is a new beginning<span class="pipe">|</span></span>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            // ── Category pill ──
            $('#categorySelect').on('change', function () {
                var $opt  = $(this).find('option:selected');
                var color = $opt.data('color') || '';
                var name  = $opt.data('name')  || '';
                if (color && name) {
                    $('#catPreviewDot').css('background', color);
                    $('#catPreviewName').text(name);
                    $('#catPreviewRow').show();
                } else {
                    $('#catPreviewRow').hide();
                }
            });

            // ── File input ──
            $('#fileInput').on('change', function () {
                var file = this.files[0];
                if (file) {
                    $('#fileName').text(file.name);
                    var kb = (file.size / 1024).toFixed(1);
                    var size = kb > 1024 ? (kb / 1024).toFixed(2) + ' MB' : kb + ' KB';
                    $('#fileSize').text(size);
                    $('#fileInfo').addClass('visible');
                    $('#dropzone').css('border-color', '#f97316').css('background', '#fff4ed');
                }
            });

            // ── Drag & drop visual ──
            var $dz = $('#dropzone');
            $dz.on('dragover', function (e) {
                e.preventDefault();
                $dz.addClass('dragover');
            });
            $dz.on('dragleave drop', function () {
                $dz.removeClass('dragover');
            });
        })();
    </script>
}