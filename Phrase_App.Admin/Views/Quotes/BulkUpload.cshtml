@{
    ViewData["Title"] = "Bulk Upload Quotes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = (IEnumerable<Phrase_App.Core.Models.Category>)ViewBag.Categories ?? new List<Phrase_App.Core.Models.Category>();
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Bulk Upload Quotes</h5>

                    <div class="alert alert-info" role="alert">
                        <strong>File Format:</strong> CSV or TXT file with one quote per line.
                        <br />
                        <strong>Format:</strong> <code>QuoteText|Author|Optional</code>
                        <br />
                        Example: <code>Success is not final|Winston Churchill</code>
                        <br />
                        Lines starting with # are ignored as comments.
                    </div>

                    <form asp-area="Admin" asp-controller="Quotes" asp-action="BulkUpload" method="post" enctype="multipart/form-data" class="row g-3">
                        @Html.AntiForgeryToken()

                        <div class="col-md-6">
                            <label class="form-label"><b>Select Category</b></label>
                            <select name="categoryId" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                            <small class="form-text text-muted">All quotes in file will be added to this category.</small>
                        </div>

                        <div class="col-md-6"></div>

                        <div class="col-12">
                            <label class="form-label"><b>Upload File</b></label>
                            <input type="file" name="file" class="form-control" accept=".csv,.txt" required />
                            <small class="form-text text-muted">Maximum file size: 10 MB. Only CSV and TXT files allowed.</small>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-success">Upload</button>
                            <a asp-area="Admin" asp-controller="Quotes" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                        </div>
                    </form>

                    <hr />

                    <h6>Sample File Format:</h6>
                    <pre class="bg-light p-3">
# This is a comment
Success is not final, failure is not fatal|Winston Churchill
The only way to do great work|Steve Jobs
Innovation distinguishes|Steve Jobs
            </pre>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/assets/libs/jquery/dist/jquery.min.js"></script>
    <script src="~/Admin/assets/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
}