@model Phrase_App.Core.Models.Quote
@{
    ViewData["Title"] = "Create Quote";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = (IEnumerable<Phrase_App.Core.Models.Category>)ViewBag.Categories ?? new List<Phrase_App.Core.Models.Category>();
}

<style>
    /* ================================================
           CREATE QUOTE — cream/dark theme
           ================================================ */
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .breadcrumb-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

        .breadcrumb-link:hover {
            color: var(--orange);
        }

    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 32px;
        box-shadow: var(--card-shadow);
    }

    .form-section {
        margin-bottom: 28px;
    }

    .form-section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-section-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .form-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    .form-label {
        font-size: 13px !important;
        font-weight: 600 !important;
        color: var(--text) !important;
        margin-bottom: 7px !important;
    }

    .form-hint {
        font-size: 12px;
        color: var(--muted-light);
        margin-top: 6px;
    }

    .form-control,
    .form-select {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 12px !important;
        font-size: 14px !important;
        color: var(--text) !important;
        transition: border-color 0.2s, box-shadow 0.2s !important;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.12) !important;
            background: #fff !important;
            outline: none !important;
        }

        .form-control::placeholder {
            color: var(--muted-light) !important;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 130px;
        line-height: 1.7;
    }

    .char-counter {
        font-size: 11px;
        color: var(--muted-light);
        text-align: right;
        margin-top: 5px;
        transition: color 0.2s;
    }

        .char-counter.warn {
            color: #f97316;
        }

        .char-counter.danger {
            color: #dc2626;
        }

    .field-validation-error {
        font-size: 12px;
        color: #dc2626;
        margin-top: 5px;
        display: block;
    }

    /* ── CATEGORY OPTION DISPLAY ── */
    .category-option-preview {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: var(--input-bg);
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        margin-top: 10px;
        transition: all 0.2s;
    }

    .category-option-dot {
        width: 12px;
        height: 12px;
        border-radius: 4px;
        flex-shrink: 0;
        transition: background 0.3s;
    }

    .category-option-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
    }

    /* ── LIVE PREVIEW CARD ── */
    .preview-affirmation {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 18px;
        padding: 24px;
        margin-bottom: 16px;
        border: 1px solid rgba(255,255,255,0.07);
        min-height: 130px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .preview-quote-text {
        font-size: 15px;
        font-weight: 600;
        color: #f1f5f9;
        line-height: 1.65;
        font-style: italic;
        margin-bottom: 16px;
        flex: 1;
    }

        .preview-quote-text.empty {
            color: #475569;
            font-style: normal;
            font-weight: 400;
            font-size: 13px;
        }

    .preview-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .preview-author {
        font-size: 12px;
        font-weight: 600;
        color: #94a3b8;
    }

    .preview-cat-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: var(--orange);
        transition: background 0.3s;
    }

    /* ── BUTTONS ── */
    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--gradient);
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(249,115,22,0.35);
        transition: opacity 0.2s, transform 0.2s;
        text-decoration: none !important;
    }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f1f5f9;
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }

    /* ── TIPS BOX ── */
    .tips-box {
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        border-radius: 14px;
        padding: 16px 18px;
        margin-top: 16px;
    }

    .tips-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--orange);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .tips-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .tips-list li {
            font-size: 12px;
            color: #92400e;
            padding: 3px 0;
            display: flex;
            align-items: flex-start;
            gap: 7px;
            line-height: 1.5;
        }

            .tips-list li::before {
                content: '•';
                color: var(--orange);
                font-weight: 700;
                flex-shrink: 0;
                margin-top: 1px;
            }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>New Affirmation</h2>
        <p>Add a new quote to your library</p>
    </div>
    <a class="breadcrumb-link" asp-area="Admin" asp-controller="Quotes" asp-action="Index">
        <i class="mdi mdi-arrow-left"></i> Back to Affirmations
    </a>
</div>

<div class="row g-4">

    <!-- Form Column -->
    <div class="col-lg-8">
        <div class="panel">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px;"></div>

            <form asp-area="Admin" asp-controller="Quotes" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- Quote Content -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="mdi mdi-format-quote-open"></i>
                        Quote Content
                    </div>

                    <label class="form-label">Affirmation Text</label>
                    <textarea name="Content"
                              id="contentInput"
                              class="form-control"
                              rows="5"
                              placeholder="Write a powerful, uplifting affirmation..."
                              required
                              maxlength="500"></textarea>
                    <div class="d-flex justify-content-between align-items-center">
                        <p class="form-hint mb-0">The main affirmation text shown to the user.</p>
                        <div class="char-counter" id="charCounter">0 / 500</div>
                    </div>
                </div>

                <!-- Author & Category -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="mdi mdi-information-outline"></i>
                        Details
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Author</label>
                            <input type="text"
                                   name="Author"
                                   id="authorInput"
                                   class="form-control"
                                   placeholder="e.g. Steve Jobs, Unknown..." />
                            <p class="form-hint">Leave blank to default to 'Unknown'.</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <select name="CategoryId" id="categorySelect" class="form-select" required>
                                <option value="">— Select a category —</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id"
                                            data-color="@cat.ColorHex"
                                            data-name="@cat.Name">
                                        @cat.Name
                                    </option>
                                }
                            </select>

                            <!-- Selected category pill -->
                            <div class="category-option-preview" id="catPreviewRow" style="display:none !important;">
                                <div class="category-option-dot" id="catPreviewDot"></div>
                                <span class="category-option-name" id="catPreviewName"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3 pt-2">
                    <button type="submit" class="btn-submit">
                        <i class="mdi mdi-check"></i> Create Affirmation
                    </button>
                    <a asp-area="Admin" asp-controller="Quotes" asp-action="Index" class="btn-cancel">
                        <i class="mdi mdi-close"></i> Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- Right Column: Preview + Tips -->
    <div class="col-lg-4">
        <div class="panel" style="position: sticky; top: 90px;">

            <div style="font-size:11px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:#64748b; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                <i class="mdi mdi-eye-outline" style="color:#f97316; font-size:16px;"></i>
                Live Preview
            </div>

            <!-- Overlay-style preview card -->
            <div class="preview-affirmation">
                <div class="preview-quote-text empty" id="previewText">
                    Your affirmation will appear here...
                </div>
                <div class="preview-footer">
                    <span class="preview-author" id="previewAuthor">— Unknown</span>
                    <span class="preview-cat-chip" id="previewCat" style="display:none;">
                        <i class="mdi mdi-tag" style="font-size:10px;"></i>
                        <span id="previewCatName">Category</span>
                    </span>
                </div>
            </div>

            <!-- App-style mini card -->
            <div style="background:#f8fafc; border-radius:12px; padding:16px;">
                <div style="font-size:12px; color:#94a3b8; margin-bottom:10px; font-weight:600;">Overlay card preview</div>
                <div style="background:#1a2235; border-radius:10px; padding:14px; display:flex; flex-direction:column; gap:8px;">
                    <div id="miniText" style="font-size:12px; color:#cbd5e1; font-style:italic; line-height:1.5;">Your affirmation text...</div>
                    <div style="display:flex; align-items:center; justify-content:space-between;">
                        <span id="miniAuthor" style="font-size:11px; color:#475569;">— Unknown</span>
                        <span id="miniCat" style="font-size:10px; font-weight:700; color:#f97316; background:rgba(249,115,22,0.1); padding:2px 8px; border-radius:10px;"></span>
                    </div>
                </div>
            </div>

            <!-- Writing tips -->
            <div class="tips-box">
                <div class="tips-title">
                    <i class="mdi mdi-lightbulb-outline"></i> Writing Tips
                </div>
                <ul class="tips-list">
                    <li>Use present tense — "I am" not "I will be"</li>
                    <li>Keep it personal and direct to the reader</li>
                    <li>Aim for under 150 characters for overlay display</li>
                    <li>Positive framing — avoid "not" or "don't"</li>
                </ul>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            var $content  = $('#contentInput');
            var $author   = $('#authorInput');
            var $catSel   = $('#categorySelect');
            var $counter  = $('#charCounter');

            // ── Char counter ──
            $content.on('input', function () {
                var len = $(this).val().length;
                $counter.text(len + ' / 500');
                $counter.removeClass('warn danger');
                if (len > 400) $counter.addClass('warn');
                if (len > 470) $counter.removeClass('warn').addClass('danger');
                updatePreview();
            });

            // ── Author update ──
            $author.on('input', function () { updatePreview(); });

            // ── Category update ──
            $catSel.on('change', function () {
                var $opt   = $(this).find('option:selected');
                var color  = $opt.data('color') || '';
                var name   = $opt.data('name')  || '';

                if (color && name) {
                    $('#catPreviewDot').css('background', color);
                    $('#catPreviewName').text(name);
                    $('#catPreviewRow').css('display', 'flex !important');
                    // preview
                    $('#previewCat').show().css('background', color);
                    $('#previewCatName').text(name);
                    $('#miniCat').text(name).css('color', color).css('background', hexToAlpha(color, 0.12));
                } else {
                    $('#catPreviewRow').css('display', 'none !important');
                    $('#previewCat').hide();
                    $('#miniCat').text('');
                }
            });

            function hexToAlpha(hex, alpha) {
                var r = parseInt(hex.slice(1,3),16);
                var g = parseInt(hex.slice(3,5),16);
                var b = parseInt(hex.slice(5,7),16);
                return 'rgba('+r+','+g+','+b+','+alpha+')';
            }

            function updatePreview() {
                var content = $content.val().trim();
                var author  = $author.val().trim() || 'Unknown';

                if (content) {
                    $('#previewText').text('"' + content + '"').removeClass('empty');
                    $('#miniText').text('"' + content + '"');
                } else {
                    $('#previewText').text('Your affirmation will appear here...').addClass('empty');
                    $('#miniText').text('Your affirmation text...');
                }

                $('#previewAuthor').text('— ' + author);
                $('#miniAuthor').text('— ' + author);
            }
        })();
    </script>
}