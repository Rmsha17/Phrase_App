@model IEnumerable<Phrase_App.Core.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Toast Container -->
            <div id="toastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Users Management</h5>

                    <div class="mb-3">
                        <form method="get" class="row g-2">
                            <div class="col-md-6">
                                <input type="text" name="searchQuery" class="form-control" placeholder="Search by username, email or name..." value="@ViewBag.SearchQuery" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">Search</button>
                            </div>
                            <div class="col-md-2">
                                <a href="@Url.Action("Index", "Users", new { area = "Admin" })" class="btn btn-secondary w-100">Clear</a>
                            </div>
                        </form>
                    </div>

                    <div class="table-responsive">
                        <table id="zero_config" class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Full Name</th>
                                    <th>Subscription</th>
                                    <th>Expiry Date</th>
                                    <th>Dark Mode</th>
                                    <th>Joined</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null)
                                {
                                    foreach (var user in Model)
                                    {
                                        var subscriptionType = user.IsPremium ? user.SubscriptionType ?? "Premium" : "Free";
                                        var expiryDate = user.PremiumExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A";
                                        var isExpired = user.PremiumExpiryDate.HasValue && user.PremiumExpiryDate.Value < DateTime.UtcNow;

                                        <tr>
                                            <td>@user.UserName</td>
                                            <td>@user.Email</td>
                                            <td>@user.FullName</td>
                                            <td>
                                                @if (user.IsPremium)
                                                {
                                                    <span class="badge bg-success">@subscriptionType</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Free</span>
                                                }
                                            </td>
                                            <td>
                                                @if (user.PremiumExpiryDate.HasValue)
                                                {
                                                    @if (isExpired)
                                                    {
                                                        <span class="badge bg-danger">@expiryDate (Expired)</span>
                                                    }
                                                    else
                                                    {
                                                        var daysLeft = (user.PremiumExpiryDate.Value - DateTime.UtcNow).Days;
                                                        @if (daysLeft <= 7)
                                                        {
                                                            <span class="badge bg-warning">@expiryDate (@daysLeft days)</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-info">@expiryDate (@daysLeft days)</span>
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input dark-mode-toggle"
                                                           type="checkbox"
                                                           data-user-id="@user.Id"
                                                           @(user.DarkMode ? "checked" : "") />
                                                </div>
                                            </td>
@*                                             <td>@user.CreatedAt?.ToString("yyyy-MM-dd")</td>
 *@                                            <td class="text-center">
                                                <a class="btn btn-sm btn-outline-primary me-1"
                                                   asp-area="Admin"
                                                   asp-controller="Users"
                                                   asp-action="Details"
                                                   asp-route-id="@user.Id">View</a>

                                                <a class="btn btn-sm btn-outline-secondary me-1"
                                                   asp-area="Admin"
                                                   asp-controller="Users"
                                                   asp-action="Edit"
                                                   asp-route-id="@user.Id">Edit</a>

                                             @*    <form asp-area="Admin"
                                                      asp-controller="Users"
                                                      asp-action="Delete"
                                                      method="post"
                                                      class="d-inline delete-user-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                </form> *@
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Full Name</th>
                                    <th>Subscription</th>
                                    <th>Expiry Date</th>
                                    <th>Dark Mode</th>
                                    <th>Joined</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/assets/extra-libs/multicheck/datatable-checkbox-init.js"></script>
    <script src="~/Admin/assets/extra-libs/multicheck/jquery.multicheck.js"></script>
    <script src="~/Admin/assets/extra-libs/DataTables/datatables.min.js"></script>

    <script>
        (function () {
            var table = $("#zero_config").DataTable({
                responsive: true,
                ordering: true,
                pageLength: 10,
                columnDefs: [
                    { orderable: false, targets: [5, 7] }
                ],
                dom:
                    '<"row mb-2"<"col-sm-6"l><"col-sm-6 text-end"f>>' +
                    't' +
                    '<"row mt-2"<"col-sm-6"i><"col-sm-6 text-end"p>>'
            });

            function alignControls() {
                var $wrap = $('#zero_config').closest('.dataTables_wrapper');
                $wrap.find('.dataTables_length').removeClass('float-end').addClass('float-start').css({ 'text-align': 'left' });
                $wrap.find('.dataTables_info').removeClass('float-end').addClass('float-start').css({ 'text-align': 'left' });
                $wrap.find('.dataTables_filter').removeClass('float-start').addClass('float-end').css({ 'text-align': 'right' });
                $wrap.find('.dataTables_paginate').removeClass('float-start').addClass('float-end').css({ 'text-align': 'right' });
                $wrap.find('.dataTables_filter input').addClass('form-control form-control-sm').css('display', 'inline-block');
            }

            alignControls();
            table.on('draw.dt', function () { alignControls(); });

            // Delete confirmation
            $('.delete-user-form').on('submit', function (e) {
                if (!confirm('Delete this user? This action cannot be undone.')) {
                    e.preventDefault();
                    return false;
                }
                return true;
            });

            // Dark Mode Toggle
            $('.dark-mode-toggle').on('change', function () {
                var userId = $(this).data('user-id');
                var checkbox = $(this);

                $.ajax({
                    url: '@Url.Action("ToggleDarkMode", "Users", new { area = "Admin" })/' + userId,
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            showToast('Dark mode toggled successfully!', 'success');
                        } else {
                            showToast('Failed to toggle dark mode', 'danger');
                            checkbox.prop('checked', !checkbox.prop('checked'));
                        }
                    },
                    error: function () {
                        showToast('An error occurred', 'danger');
                        checkbox.prop('checked', !checkbox.prop('checked'));
                    }
                });
            });

            // Toast notification function
            function showToast(message, type = 'success') {
                var toastHtml = `
                    <div class="toast align-items-center text-white bg-${type} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                ${message}
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `;
                var $container = $('#toastContainer');
                var $toast = $(toastHtml);
                $container.append($toast);

                var bsToast = new bootstrap.Toast($toast[0]);
                bsToast.show();

                $toast.on('hidden.bs.toast', function () {
                    $toast.remove();
                });
            }

            // Check for TempData messages and show toast
            @if (TempData["Success"] != null)
            {
                    <text>showToast('@TempData["Success"]', 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                    <text>showToast('@TempData["Error"]', 'danger');</text>
            }
        })();
    </script>
}