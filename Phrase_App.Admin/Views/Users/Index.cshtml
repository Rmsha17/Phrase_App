@model IEnumerable<Phrase_App.Core.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users";
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    /* ── SEARCH BAR ── */
    .search-bar {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 16px 20px;
        box-shadow: var(--card-shadow);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .search-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
    }

        .search-label i {
            color: var(--orange);
        }

    .search-input {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 10px !important;
        padding: 9px 14px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        flex: 1;
        min-width: 240px;
        transition: border-color 0.2s, box-shadow 0.2s !important;
        box-shadow: none !important;
    }

        .search-input:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.12) !important;
            outline: none !important;
        }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--gradient);
        color: #fff !important;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(249,115,22,0.3);
        transition: opacity 0.2s;
        text-decoration: none !important;
    }

        .btn-search:hover {
            opacity: 0.88;
        }

    .btn-clear {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #f1f5f9;
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 10px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-clear:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }

    /* ── PANEL ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 28px;
        box-shadow: var(--card-shadow);
    }

    /* ── DATATABLE ── */
    .dataTables_filter input {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 10px !important;
        padding: 7px 14px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        outline: none !important;
        margin-left: 8px !important;
    }

        .dataTables_filter input:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.1) !important;
        }

    .dataTables_filter label,
    .dataTables_length label {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
    }

    .dataTables_length select {
        background: var(--input-bg) !important;
        border: 1.5px solid var(--input-border) !important;
        border-radius: 8px !important;
        padding: 5px 10px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        margin: 0 6px !important;
    }

    .dataTables_info {
        font-size: 13px;
        color: var(--muted);
        padding-top: 10px !important;
    }

    /* ── TABLE ── */
    table.dataTable {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: 100% !important;
    }

        table.dataTable thead th {
            font-size: 11px !important;
            font-weight: 700 !important;
            letter-spacing: 1px !important;
            text-transform: uppercase !important;
            color: var(--muted) !important;
            border: none !important;
            border-bottom: 2px solid #e2e8f0 !important;
            padding: 14px 16px !important;
            background: #f8fafc !important;
            white-space: nowrap;
        }

        table.dataTable tbody tr {
            transition: background 0.15s;
        }

            table.dataTable tbody tr:hover {
                background: #fff9f5 !important;
            }

        table.dataTable tbody td {
            font-size: 13px !important;
            color: var(--text) !important;
            border: none !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 13px 16px !important;
            vertical-align: middle !important;
        }

        table.dataTable.table-striped tbody tr:nth-of-type(odd) {
            background: transparent !important;
        }

    /* ── USER CELL ── */
    .user-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-avatar {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        color: var(--orange);
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
    }

    .user-email {
        font-size: 11px;
        color: var(--muted);
        margin-top: 1px;
    }

    /* ── SUBSCRIPTION BADGE ── */
    .sub-premium {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: linear-gradient(135deg, rgba(249,115,22,0.12), rgba(251,191,36,0.12));
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .sub-free {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: var(--muted);
        border: 1px solid var(--input-border);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    /* ── EXPIRY BADGES ── */
    .expiry-expired {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff5f5;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .expiry-warn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    .expiry-ok {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
    }

    /* ── ACCOUNT STATUS BADGE ── */
    .status-active {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .status-locked {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff5f5;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-active .status-dot {
        background: #16a34a;
        animation: blink 2s infinite;
    }

    .status-locked .status-dot {
        background: #dc2626;
    }

    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── DARK MODE TOGGLE ── */
    .form-check-input.dark-mode-toggle {
        width: 36px !important;
        height: 20px !important;
        cursor: pointer;
        border-radius: 20px !important;
    }

        .form-check-input.dark-mode-toggle:checked {
            background-color: var(--orange) !important;
            border-color: var(--orange) !important;
        }

    /* ── DATE CELL ── */
    .date-cell {
        font-size: 12px;
        color: var(--muted);
        font-weight: 500;
        white-space: nowrap;
    }

    /* ── ACTION BUTTONS ── */
    .btn-view {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-light);
        color: var(--orange) !important;
        border: 1px solid var(--orange-border);
        border-radius: 9px;
        padding: 6px 13px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-view:hover {
            background: #fed7aa;
            color: #c2410c !important;
        }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: #475569 !important;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 6px 13px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-edit:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }

    /* ── PAGINATION ── */
    .dataTables_paginate .paginate_button {
        border-radius: 9px !important;
        border: 1px solid #e2e8f0 !important;
        background: #fff !important;
        color: var(--muted) !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        margin: 0 2px !important;
        padding: 6px 12px !important;
        transition: all 0.2s !important;
    }

        .dataTables_paginate .paginate_button:hover {
            background: var(--orange-light) !important;
            border-color: var(--orange-border) !important;
            color: var(--orange) !important;
        }

        .dataTables_paginate .paginate_button.current,
        .dataTables_paginate .paginate_button.current:hover {
            background: var(--gradient) !important;
            border-color: transparent !important;
            color: #fff !important;
            box-shadow: 0 3px 10px rgba(249,115,22,0.3) !important;
        }

        .dataTables_paginate .paginate_button.disabled,
        .dataTables_paginate .paginate_button.disabled:hover {
            opacity: 0.4 !important;
            cursor: default !important;
        }

    @@keyframes slideIn {
        from {
            transform: translateX(30px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

<!-- Toast Container -->
<div id="toastContainer" style="position:fixed; top:24px; right:24px; z-index:9999;"></div>

<!-- Antiforgery token for AJAX -->
@Html.AntiForgeryToken()

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>Users Management</h2>
        <p>View and manage all registered users</p>
    </div>
</div>

<!-- Search Bar -->
<div class="search-bar">
    <span class="search-label">
        <i class="mdi mdi-magnify"></i> Search
    </span>
    <form method="get" style="display:contents;">
        <input type="text"
               name="searchQuery"
               class="search-input"
               placeholder="Search by username, email or name..."
               value="@ViewBag.SearchQuery" />
        <button type="submit" class="btn-search">
            <i class="mdi mdi-magnify"></i> Search
        </button>
        <a href="@Url.Action("Index", "Users", new { area = "Admin" })" class="btn-clear">
            <i class="mdi mdi-close"></i> Clear
        </a>
    </form>
</div>

<!-- Table Panel -->
<div class="panel">
    <div class="table-responsive">
        <table id="zero_config" class="table table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Full Name</th>
                    <th>Subscription</th>
                    <th>Expiry Date</th>
                    <th>Account Status</th>
                    <th>Joined</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var user in Model)
                    {
                        var subscriptionType = user.IsPremium ? user.SubscriptionType ?? "Premium" : "Free";
                        var expiryDate = user.PremiumExpiryDate?.ToString("MMM dd, yyyy") ?? "N/A";
                        var isExpired = user.PremiumExpiryDate.HasValue && user.PremiumExpiryDate.Value < DateTime.UtcNow;
                        var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow;
                        var initial = string.IsNullOrEmpty(user.UserName) ? "?" : user.UserName.Substring(0, 1).ToUpper();

                        <tr>
                            <!-- User (avatar + username + email) -->
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">@initial</div>
                                    <div>
                                        <div class="user-name">@user.UserName</div>
                                        <div class="user-email">@user.Email</div>
                                    </div>
                                </div>
                            </td>

                            <!-- Full Name -->
                            <td style="font-size:13px; font-weight:500;">@user.FullName</td>

                            <!-- Subscription -->
                            <td>
                                @if (user.IsPremium)
                                {
                                    <span class="sub-premium">
                                        <i class="mdi mdi-crown" style="font-size:11px;"></i>
                                        @subscriptionType
                                    </span>
                                }
                                else
                                {
                                    <span class="sub-free">
                                        <i class="mdi mdi-account-outline" style="font-size:11px;"></i>
                                        Free
                                    </span>
                                }
                            </td>

                            <!-- Expiry Date -->
                            <td>
                                @if (user.PremiumExpiryDate.HasValue)
                                {
                                    if (isExpired)
                                    {
                                        <span class="expiry-expired">
                                            <i class="mdi mdi-calendar-remove" style="font-size:11px;"></i>
                                            @expiryDate
                                        </span>
                                    }
                                    else
                                    {
                                        var daysLeft = (user.PremiumExpiryDate.Value - DateTime.UtcNow).Days;
                                        if (daysLeft <= 7)
                                        {
                                            <span class="expiry-warn">
                                                <i class="mdi mdi-clock-alert-outline" style="font-size:11px;"></i>
                                                @expiryDate · @daysLeft days
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="expiry-ok">
                                                <i class="mdi mdi-calendar-check" style="font-size:11px;"></i>
                                                @expiryDate · @daysLeft days
                                            </span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span style="font-size:12px; color:var(--muted-light);">—</span>
                                }
                            </td>

                            <!-- Account Status (LockoutEnd) -->
                            <td>
                                @if (isLocked)
                                {
                                    <span class="status-locked">
                                        <span class="status-dot"></span>
                                        Deactivated
                                    </span>
                                }
                                else
                                {
                                    <span class="status-active">
                                        <span class="status-dot"></span>
                                        Active
                                    </span>
                                }
                            </td>

                            <!-- Joined -->
                            <td>
                                <div class="date-cell">@user.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </td>

                            <!-- Actions -->
                            <td class="text-center" style="white-space:nowrap;">
                                <a class="btn-view"
                                   asp-area="Admin"
                                   asp-controller="Users"
                                   asp-action="Details"
                                   asp-route-id="@user.Id">
                                    <i class="mdi mdi-eye-outline"></i> View
                                </a>
                                <a class="btn-edit ms-1"
                                   asp-area="Admin"
                                   asp-controller="Users"
                                   asp-action="Edit"
                                   asp-route-id="@user.Id">
                                    <i class="mdi mdi-pencil-outline"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>User</th>
                    <th>Full Name</th>
                    <th>Subscription</th>
                    <th>Expiry Date</th>
                    <th>Account Status</th>
                    <th>Joined</th>
                    <th class="text-center">Actions</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/assets/extra-libs/multicheck/datatable-checkbox-init.js"></script>
    <script src="~/Admin/assets/extra-libs/multicheck/jquery.multicheck.js"></script>
    <script src="~/Admin/assets/extra-libs/DataTables/datatables.min.js"></script>

    <script>
        (function () {
            var table = $("#zero_config").DataTable({
                responsive: true,
                ordering: true,
                pageLength: 10,
                columnDefs: [
                    { orderable: false, targets: [5, 7] }
                ],
                dom:
                    '<"row mb-3 align-items-center"<"col-sm-6"l><"col-sm-6 text-end"f>>' +
                    't' +
                    '<"row mt-3 align-items-center"<"col-sm-6"i><"col-sm-6 text-end"p>>'
            });

            function alignControls() {
                var $wrap = $('#zero_config').closest('.dataTables_wrapper');
                $wrap.find('.dataTables_length').css('text-align', 'left');
                $wrap.find('.dataTables_info').css('text-align',  'left');
                $wrap.find('.dataTables_filter').css('text-align', 'right');
                $wrap.find('.dataTables_paginate').css('text-align', 'right');
            }

            alignControls();
            table.on('draw.dt', function () { alignControls(); });

            // ── Toast ──
            function showToast(message, type) {
                var iconMap   = { success: 'check-circle', danger: 'alert-circle' };
                var colorMap  = { success: '#16a34a',      danger: '#dc2626'      };
                var bgMap     = { success: '#f0fdf4',       danger: '#fff5f5'      };
                var borderMap = { success: '#bbf7d0',       danger: '#fecaca'      };

                var $toast = $(`
                    <div style="
                        background:${bgMap[type]||'#fff'};
                        border:1.5px solid ${borderMap[type]||'#e2e8f0'};
                        border-radius:14px; padding:14px 18px;
                        display:flex; align-items:center; gap:12px;
                        min-width:260px; box-shadow:0 8px 24px rgba(0,0,0,0.12);
                        margin-bottom:10px; animation:slideIn 0.3s ease;">
                        <i class="mdi mdi-${iconMap[type]||'information'}"
                           style="font-size:20px; color:${colorMap[type]||'#f97316'}; flex-shrink:0;"></i>
                        <span style="font-size:14px; font-weight:500; color:#1e293b;">${message}</span>
                    </div>
                `);
                $('#toastContainer').append($toast);
                setTimeout(function () {
                    $toast.fadeOut(300, function () { $toast.remove(); });
                }, 3500);
            }

            @if (TempData["Success"] != null)
            {
                    <text>showToast('@TempData["Success"]', 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                    <text>showToast('@TempData["Error"]', 'danger');</text>
            }
        })();
    </script>
}