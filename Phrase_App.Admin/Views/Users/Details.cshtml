@model Phrase_App.Core.Models.ApplicationUser

@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = (IEnumerable<string>)ViewBag.Roles ?? new List<string>();
    var isLocked = Model.LockoutEnd.HasValue && Model.LockoutEnd.Value > DateTimeOffset.UtcNow;
    var isExpired = Model.PremiumExpiryDate.HasValue && Model.PremiumExpiryDate.Value < DateTime.UtcNow;
    var daysLeft = Model.PremiumExpiryDate.HasValue && !isExpired
                    ? (int)(Model.PremiumExpiryDate.Value - DateTime.UtcNow).TotalDays
                    : 0;
    var initial = string.IsNullOrEmpty(Model.UserName) ? "?" : Model.UserName.Substring(0, 1).ToUpper();
}

<style>
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --input-bg: #f8fafc;
        --input-border: #e2e8f0;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .breadcrumb-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

        .breadcrumb-link:hover {
            color: var(--orange);
        }

    /* ── PANELS ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 28px;
        box-shadow: var(--card-shadow);
        margin-bottom: 24px;
    }

    .panel-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .panel-title i {
            color: var(--orange);
            font-size: 16px;
        }

        .panel-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f1f5f9;
        }

    /* ── HERO PROFILE ── */
    .hero {
        background: linear-gradient(135deg, #1a2235 0%, #263044 100%);
        border-radius: 20px;
        padding: 28px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .hero-avatar {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        background: var(--gradient);
        color: #fff;
        font-size: 32px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 6px 20px rgba(249,115,22,0.45);
    }

    .hero-name {
        font-size: 20px;
        font-weight: 800;
        color: #f1f5f9;
        margin-bottom: 4px;
        letter-spacing: -0.3px;
    }

    .hero-email {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 10px;
    }

    .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .hero-actions {
        margin-left: auto;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }

    /* ── INFO ROWS ── */
    .info-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 0;
        border-bottom: 1px solid #f1f5f9;
        gap: 12px;
    }

        .info-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .info-key {
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

        .info-key i {
            color: var(--orange);
            font-size: 15px;
            width: 18px;
            text-align: center;
        }

    .info-val {
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
        text-align: right;
        word-break: break-all;
    }

    /* ── BADGES ── */
    .badge-premium {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: linear-gradient(135deg,rgba(249,115,22,0.15),rgba(251,191,36,0.15));
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-free {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: var(--muted);
        border: 1px solid var(--input-border);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-active {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-locked {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff5f5;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-confirmed {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-pending {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-role {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-dark {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #1e293b;
        color: #94a3b8;
        border: 1px solid #334155;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .badge-light {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f8fafc;
        color: var(--muted);
        border: 1px solid var(--input-border);
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .badge-active .status-dot {
        background: #16a34a;
        animation: blink 2s infinite;
    }

    .badge-locked .status-dot {
        background: #dc2626;
    }

    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* Expiry badges */
    .expiry-expired {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff5f5;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .expiry-warn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    .expiry-ok {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 700;
    }

    /* ── TOKEN BOX ── */
    .token-box {
        background: #1a2235;
        border-radius: 10px;
        padding: 10px 14px;
        font-family: 'Courier New', monospace;
        font-size: 11px;
        color: #94a3b8;
        word-break: break-all;
        border: 1px solid rgba(255,255,255,0.06);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .token-box i {
            color: var(--orange);
            flex-shrink: 0;
        }

    /* ── STAT TILES ── */
    .stat-tile {
        background: var(--input-bg);
        border: 1px solid var(--input-border);
        border-radius: 14px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .stat-tile-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--orange-light);
        border: 1px solid var(--orange-border);
        color: var(--orange);
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-tile-label {
        font-size: 11px;
        color: var(--muted);
        font-weight: 600;
        margin-bottom: 3px;
    }

    .stat-tile-val {
        font-size: 18px;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
    }

    /* ── ACTION BUTTONS ── */
    .btn-edit-action {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--gradient);
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 700;
        box-shadow: 0 4px 14px rgba(249,115,22,0.35);
        text-decoration: none !important;
        transition: opacity 0.2s, transform 0.2s;
    }

        .btn-edit-action:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: #fff !important;
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f1f5f9;
        color: var(--muted) !important;
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: var(--text) !important;
        }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>User Details</h2>
        <p>Full profile and account information</p>
    </div>
    <a class="breadcrumb-link" asp-area="Admin" asp-controller="Users" asp-action="Index">
        <i class="mdi mdi-arrow-left"></i> Back to Users
    </a>
</div>

<!-- Hero Card -->
<div class="hero">
    <div class="hero-avatar">@initial</div>
    <div>
        <div class="hero-name">@Model.FullName</div>
        <div class="hero-email">@Model.Email</div>
        <div class="hero-badges">
            @if (Model.IsPremium)
            {
                <span class="badge-premium">
                    <i class="mdi mdi-crown" style="font-size:11px;"></i>
                    @(Model.SubscriptionType ?? "Premium")
                </span>
            }
            else
            {
                <span class="badge-free">
                    <i class="mdi mdi-account-outline" style="font-size:11px;"></i>
                    Free
                </span>
            }

            @if (isLocked)
            {
                <span class="badge-locked">
                    <span class="status-dot"></span> Deactivated
                </span>
            }
            else
            {
                <span class="badge-active">
                    <span class="status-dot"></span> Active
                </span>
            }

            @foreach (var role in roles)
            {
                <span class="badge-role">
                    <i class="mdi mdi-shield-account-outline" style="font-size:11px;"></i>
                    @role
                </span>
            }
        </div>
    </div>
    <div class="hero-actions">
        <a asp-area="Admin" asp-controller="Users"
           asp-action="Edit" asp-route-id="@Model.Id"
           class="btn-edit-action">
            <i class="mdi mdi-pencil-outline"></i> Edit User
        </a>
    </div>
</div>

<!-- Stat Tiles Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-tile">
            <div class="stat-tile-icon"><i class="mdi mdi-calendar"></i></div>
            <div>
                <div class="stat-tile-label">Member Since</div>
                <div class="stat-tile-val" style="font-size:14px;">@Model.CreatedAt.ToString("MMM yyyy")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-tile">
            <div class="stat-tile-icon"><i class="mdi mdi-crown"></i></div>
            <div>
                <div class="stat-tile-label">Plan</div>
                <div class="stat-tile-val" style="font-size:14px;">@(Model.IsPremium ? "Premium" : "Free")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-tile">
            <div class="stat-tile-icon"><i class="mdi mdi-calendar-clock"></i></div>
            <div>
                <div class="stat-tile-label">Days Left</div>
                <div class="stat-tile-val">@(Model.PremiumExpiryDate.HasValue ? (isExpired ? "Expired" : daysLeft + "d") : "—")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-tile">
            <div class="stat-tile-icon"><i class="mdi mdi-theme-light-dark"></i></div>
            <div>
                <div class="stat-tile-label">Dark Mode</div>
                <div class="stat-tile-val" style="font-size:14px;">@(Model.DarkMode ? "On" : "Off")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    <!-- Left Column -->
    <div class="col-lg-6">

        <!-- Basic Information -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-account-outline"></i>
                Basic Information
            </div>

            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-at"></i> Username</span>
                <span class="info-val" style="font-weight:700;">@Model.UserName</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-email-outline"></i> Email</span>
                <span class="info-val">@Model.Email</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-account-outline"></i> Full Name</span>
                <span class="info-val">@(string.IsNullOrEmpty(Model.FullName) ? "—" : Model.FullName)</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-phone"></i> Phone</span>
                <span class="info-val">@(Model.PhoneNumber ?? "—")</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-calendar-plus"></i> Joined</span>
                <span class="info-val">@Model.CreatedAt.ToString("MMM dd, yyyy · HH:mm UTC")</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-account-box"></i> Roles</span>
                <span class="info-val">
                    @if (roles.Any())
                    {
                        foreach (var role in roles)
                        {
                            <span class="badge-role" style="margin-left:4px;">@role</span>
                        }
                    }
                    else
                    {
                        <span style="color:var(--muted-light); font-size:12px;">No roles assigned</span>
                    }
                </span>
            </div>
        </div>

        <!-- Preferences & Security -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-tune"></i>
                Preferences & Security
            </div>

            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-theme-light-dark"></i> Dark Mode</span>
                <span class="info-val">
                    @if (Model.DarkMode)
                    {
                        <span class="badge-dark"><i class="mdi mdi-moon-waning-crescent" style="font-size:11px;"></i> Enabled</span>
                    }
                    else
                    {
                        <span class="badge-light"><i class="mdi mdi-white-balance-sunny" style="font-size:11px;"></i> Disabled</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-email-secure"></i> Email Confirmed</span>
                <span class="info-val">
                    @if (Model.EmailConfirmed)
                    {
                        <span class="badge-confirmed"><i class="mdi mdi-check" style="font-size:11px;"></i> Confirmed</span>
                    }
                    else
                    {
                        <span class="badge-pending"><i class="mdi mdi-flag-checkered" style="font-size:11px;"></i> Pending</span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-shield"></i> Account Status</span>
                <span class="info-val">
                    @if (isLocked)
                    {
                        <span class="badge-locked">
                            <span class="status-dot"></span> Deactivated
                        </span>
                    }
                    else
                    {
                        <span class="badge-active">
                            <span class="status-dot"></span> Active
                        </span>
                    }
                </span>
            </div>
            @if (isLocked && Model.LockoutEnd.HasValue)
            {
                <div class="info-row">
                    <span class="info-key"><i class="mdi mdi-lock-clock"></i> Locked Until</span>
                    <span class="info-val" style="color:#dc2626; font-weight:600;">
                        @Model.LockoutEnd.Value.ToString("MMM dd, yyyy · HH:mm UTC")
                    </span>
                </div>
            }
        </div>

    </div>

    <!-- Right Column -->
    <div class="col-lg-6">

        <!-- Subscription Information -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-crown-outline"></i>
                Subscription
            </div>

            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-star-outline"></i> Status</span>
                <span class="info-val">
                    @if (Model.IsPremium)
                    {
                        <span class="badge-premium">
                            <i class="mdi mdi-crown" style="font-size:11px;"></i> Premium
                        </span>
                    }
                    else
                    {
                        <span class="badge-free">
                            <i class="mdi mdi-account-outline" style="font-size:11px;"></i> Free
                        </span>
                    }
                </span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-tag-outline"></i> Type</span>
                <span class="info-val">@(Model.SubscriptionType ?? "—")</span>
            </div>
            <div class="info-row">
                <span class="info-key"><i class="mdi mdi-calendar-question"></i> Expiry Date</span>
                <span class="info-val">
                    @if (Model.PremiumExpiryDate.HasValue)
                    {
                        if (isExpired)
                        {
                            <span class="expiry-expired">
                                <i class="mdi mdi-calendar-remove" style="font-size:11px;"></i>
                                @Model.PremiumExpiryDate.Value.ToString("MMM dd, yyyy") · Expired
                            </span>
                        }
                        else if (daysLeft <= 7)
                        {
                            <span class="expiry-warn">
                                <i class="mdi mdi-clock-alert-outline" style="font-size:11px;"></i>
                                @Model.PremiumExpiryDate.Value.ToString("MMM dd, yyyy") · @daysLeft days
                            </span>
                        }
                        else
                        {
                            <span class="expiry-ok">
                                <i class="mdi mdi-calendar-check" style="font-size:11px;"></i>
                                @Model.PremiumExpiryDate.Value.ToString("MMM dd, yyyy") · @daysLeft days
                            </span>
                        }
                    }
                    else
                    {
                        <span style="color:var(--muted-light); font-size:12px;">—</span>
                    }
                </span>
            </div>

            <!-- Purchase Token -->
            <div class="info-row" style="flex-direction:column; align-items:flex-start; gap:10px;">
                <span class="info-key"><i class="mdi mdi-key"></i> Purchase Token</span>
                @if (!string.IsNullOrEmpty(Model.CurrentPurchaseToken))
                {
                    <div class="token-box" style="width:100%;">
                        <i class="mdi mdi-key-variant"></i>
                        <span>@Model.CurrentPurchaseToken.Substring(0, Math.Min(40, Model.CurrentPurchaseToken.Length))…</span>
                    </div>
                }
                else
                {
                    <span style="color:var(--muted-light); font-size:12px;">No purchase token on record</span>
                }
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="panel">
            <div class="panel-title">
                <i class="mdi mdi-lightning-bolt"></i>
                Quick Actions
            </div>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-area="Admin" asp-controller="Users"
                   asp-action="Edit" asp-route-id="@Model.Id"
                   class="btn-edit-action">
                    <i class="mdi mdi-pencil-outline"></i> Edit User
                </a>
                <a asp-area="Admin" asp-controller="Users"
                   asp-action="Index"
                   class="btn-back">
                    <i class="mdi mdi-account-group-outline"></i> All Users
                </a>
            </div>
        </div>

    </div>
</div>