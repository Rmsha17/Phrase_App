@model IEnumerable<Phrase_App.Core.DTOs.Response.CategoryResponse>

<style>
    /* ================================================
           CATEGORIES PAGE — matches cream/dark theme
           ================================================ */
    :root {
        --orange: #f97316;
        --orange-light: #fff4ed;
        --orange-border: #fed7aa;
        --amber: #fbbf24;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.06);
        --card-shadow: 0 1px 12px rgba(0,0,0,0.07), 0 4px 24px rgba(0,0,0,0.04);
        --text: #1e293b;
        --muted: #64748b;
        --muted-light: #94a3b8;
        --gradient: linear-gradient(135deg, #f97316 0%, #fbbf24 100%);
    }

    /* ── PAGE HEADER ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
    }

        .page-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 4px;
            letter-spacing: -0.4px;
        }

        .page-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    /* ── NEW CATEGORY BUTTON ── */
    .btn-new {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--gradient);
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none !important;
        box-shadow: 0 4px 16px rgba(249,115,22,0.35);
        transition: opacity 0.2s, transform 0.2s;
    }

        .btn-new:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: #fff !important;
        }

    /* ── PANEL CARD ── */
    .panel {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 28px;
        box-shadow: var(--card-shadow);
    }

    /* ── DATATABLE OVERRIDES ── */

    /* Search input */
    .dataTables_filter input {
        background: #f8fafc !important;
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 10px !important;
        padding: 7px 14px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        outline: none !important;
        transition: border-color 0.2s !important;
        margin-left: 8px !important;
    }

        .dataTables_filter input:focus {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.1) !important;
        }

    .dataTables_filter label,
    .dataTables_length label {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
    }

    .dataTables_length select {
        background: #f8fafc !important;
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 8px !important;
        padding: 5px 10px !important;
        font-size: 13px !important;
        color: var(--text) !important;
        margin: 0 6px !important;
    }

    .dataTables_info {
        font-size: 13px;
        color: var(--muted);
        padding-top: 10px !important;
    }

    /* ── TABLE ── */
    table.dataTable {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: 100% !important;
    }

        table.dataTable thead tr {
            background: #f8fafc;
        }

        table.dataTable thead th {
            font-size: 11px !important;
            font-weight: 700 !important;
            letter-spacing: 1px !important;
            text-transform: uppercase !important;
            color: var(--muted) !important;
            border: none !important;
            border-bottom: 2px solid #e2e8f0 !important;
            padding: 14px 16px !important;
            background: #f8fafc !important;
            white-space: nowrap;
        }

            /* Sort icons */
            table.dataTable thead th.sorting::after,
            table.dataTable thead th.sorting_asc::after,
            table.dataTable thead th.sorting_desc::after {
                color: var(--orange) !important;
                opacity: 0.7;
            }

        table.dataTable tbody tr {
            transition: background 0.15s;
        }

            table.dataTable tbody tr:hover {
                background: #fff9f5 !important;
            }

        table.dataTable tbody td {
            font-size: 13.5px !important;
            color: var(--text) !important;
            border: none !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 14px 16px !important;
            vertical-align: middle !important;
        }

        /* Remove striping — clean rows look better */
        table.dataTable.table-striped tbody tr:nth-of-type(odd) {
            background: transparent !important;
        }

    /* ── CATEGORY NAME CELL ── */
    .cat-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cat-avatar {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
    }

    .cat-name-text {
        font-weight: 600;
        color: var(--text);
        font-size: 14px;
    }

    /* ── ICON KEY ── */
    .icon-key-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: var(--muted);
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 600;
        font-family: 'Courier New', monospace;
    }

    /* ── COLOR SWATCH ── */
    .color-swatch {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .color-dot {
        width: 20px;
        height: 20px;
        border-radius: 6px;
        border: 2px solid rgba(0,0,0,0.08);
        flex-shrink: 0;
    }

    .color-hex {
        font-size: 12px;
        font-weight: 600;
        color: var(--muted);
        font-family: 'Courier New', monospace;
    }

    /* ── QUOTES COUNT ── */
    .quotes-count {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--orange-light);
        color: var(--orange);
        border: 1px solid var(--orange-border);
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 12px;
        font-weight: 700;
    }

    /* ── ACTION BUTTONS ── */
    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #f1f5f9;
        color: #475569 !important;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none !important;
        transition: all 0.2s;
    }

        .btn-edit:hover {
            background: var(--orange-light);
            border-color: var(--orange-border);
            color: var(--orange) !important;
        }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff5f5;
        color: #dc2626 !important;
        border: 1px solid #fecaca;
        border-radius: 9px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #fca5a5;
        }

    /* ── PAGINATION ── */
    .dataTables_paginate .paginate_button {
        border-radius: 9px !important;
        border: 1px solid #e2e8f0 !important;
        background: #fff !important;
        color: var(--muted) !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        margin: 0 2px !important;
        padding: 6px 12px !important;
        transition: all 0.2s !important;
    }

        .dataTables_paginate .paginate_button:hover {
            background: var(--orange-light) !important;
            border-color: var(--orange-border) !important;
            color: var(--orange) !important;
        }

        .dataTables_paginate .paginate_button.current,
        .dataTables_paginate .paginate_button.current:hover {
            background: var(--gradient) !important;
            border-color: transparent !important;
            color: #fff !important;
            box-shadow: 0 3px 10px rgba(249,115,22,0.3) !important;
        }

        .dataTables_paginate .paginate_button.disabled,
        .dataTables_paginate .paginate_button.disabled:hover {
            opacity: 0.4 !important;
            cursor: default !important;
        }

    /* ── TOAST ── */
    #toastContainer .toast {
        border-radius: 12px !important;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15) !important;
        font-size: 14px !important;
    }
</style>

<!-- Toast Container -->
<div id="toastContainer" style="position:fixed; top:24px; right:24px; z-index:9999;"></div>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2>Categories</h2>
        <p>Manage affirmation categories and their content</p>
    </div>
    <a class="btn-new" asp-area="Admin" asp-controller="Categories" asp-action="Create">
        <i class="mdi mdi-plus"></i> New Category
    </a>
</div>

<!-- Table Panel -->
<div class="panel">
    <div class="table-responsive">
        <table id="zero_config" class="table table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Icon Key</th>
                    <th>Color</th>
                    <th>Quotes</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="cat-name-cell">
                                    <div class="cat-avatar" style="background:@item.ColorHex;">
                                        @item.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="cat-name-text">@item.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="icon-key-badge">
                                    <i class="mdi mdi-pound" style="font-size:11px;"></i>
                                    @item.IconKey
                                </span>
                            </td>
                            <td>
                                <div class="color-swatch">
                                    <div class="color-dot" style="background:@item.ColorHex;"></div>
                                    <span class="color-hex">@item.ColorHex</span>
                                </div>
                            </td>
                            <td>
                                <span class="quotes-count">
                                    <i class="mdi mdi-format-quote-open" style="font-size:11px;"></i>
                                    @item.count
                                </span>
                            </td>
                            <td class="text-center">
                                <a class="btn-edit"
                                   asp-area="Admin"
                                   asp-controller="Categories"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id">
                                    <i class="mdi mdi-pencil-outline"></i> Edit
                                </a>

                                <form asp-area="Admin"
                                      asp-controller="Categories"
                                      asp-action="Delete"
                                      method="post"
                                      class="d-inline delete-category-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn-delete">
                                        <i class="mdi mdi-trash-can-outline"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>Name</th>
                    <th>Icon Key</th>
                    <th>Color</th>
                    <th>Quotes</th>
                    <th class="text-center">Actions</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/assets/extra-libs/multicheck/datatable-checkbox-init.js"></script>
    <script src="~/Admin/assets/extra-libs/multicheck/jquery.multicheck.js"></script>
    <script src="~/Admin/assets/extra-libs/DataTables/datatables.min.js"></script>

    <script>
        (function () {
            var table = $("#zero_config").DataTable({
                responsive: true,
                ordering: true,
                pageLength: 10,
                dom:
                    '<"row mb-3 align-items-center"<"col-sm-6"l><"col-sm-6 text-end"f>>' +
                    't' +
                    '<"row mt-3 align-items-center"<"col-sm-6"i><"col-sm-6 text-end"p>>'
            });

            function alignControls() {
                var $wrap = $('#zero_config').closest('.dataTables_wrapper');
                $wrap.find('.dataTables_length').css('text-align', 'left');
                $wrap.find('.dataTables_info').css('text-align', 'left');
                $wrap.find('.dataTables_filter').css('text-align', 'right');
                $wrap.find('.dataTables_paginate').css('text-align', 'right');
            }

            alignControls();
            table.on('draw.dt', function () { alignControls(); });

            // Delete confirmation using SweetAlert2
            $('.delete-category-form').on('submit', function (e) {
                e.preventDefault();
                var $form = $(this);
                Swal.fire({
                    title: 'Delete Category?',
                    text: "This will permanently remove the category.",
                    icon: 'warning',
                    background: '#1a2235',
                    color: '#f1f5f9',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#475569',
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel',
                    borderRadius: '16px'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $form[0].submit();
                    }
                });
            });

            // Toast function
            function showToast(message, type) {
                var iconMap = {
                    success: 'check-circle',
                    danger:  'alert-circle'
                };
                var colorMap = {
                    success: '#16a34a',
                    danger:  '#dc2626'
                };
                var bgMap = {
                    success: '#f0fdf4',
                    danger:  '#fff5f5'
                };
                var borderMap = {
                    success: '#bbf7d0',
                    danger:  '#fecaca'
                };

                var icon  = iconMap[type]   || 'information';
                var color = colorMap[type]  || '#f97316';
                var bg    = bgMap[type]     || '#fff';
                var bdr   = borderMap[type] || '#e2e8f0';

                var toastHtml = `
                    <div style="
                        background: ${bg};
                        border: 1.5px solid ${bdr};
                        border-radius: 14px;
                        padding: 14px 18px;
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        min-width: 260px;
                        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
                        margin-bottom: 10px;
                        animation: slideIn 0.3s ease;
                    ">
                        <i class="mdi mdi-${icon}" style="font-size:20px; color:${color}; flex-shrink:0;"></i>
                        <span style="font-size:14px; font-weight:500; color:#1e293b;">${message}</span>
                    </div>
                `;

                var $toast = $(toastHtml);
                $('#toastContainer').append($toast);
                setTimeout(function () {
                    $toast.fadeOut(300, function () { $toast.remove(); });
                }, 3500);
            }

            @if (TempData["Success"] != null)
            {
                    <text>showToast('@TempData["Success"]', 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                    <text>showToast('@TempData["Error"]', 'danger');</text>
            }
        })();
    </script>

    <style>
        @@keyframes slideIn {
            from {
                transform: translateX(30px);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
}
